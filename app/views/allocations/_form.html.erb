<%= form_with(model: allocation, local: true) do |f| %>
  <div class="app-form-card">
    <% if allocation.errors.any? %>
      <div class="app-form-errors">
        <h2><%= pluralize(allocation.errors.count, "error") %> found</h2>
        <ul>
          <% allocation.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="app-form-grid two-col">
      <div class="app-form-field">
        <%= f.label :asset_id, "Asset" %>
        <%= f.collection_select :asset_id, Asset.order(:name), :id, :name, { prompt: "Select asset" }, class: "form-control" %>
      </div>

      <div class="app-form-field">
        <%= f.label :to_id, "TO" %>
        <%= f.collection_select :to_id, To.order(:name), :id, :name, { prompt: "Select TO" }, class: "form-control" %>
      </div>

      <div class="app-form-field">
        <%= f.label :allocated_at, "Allocation Date" %>
        <%= f.date_field :allocated_at %>
      </div>
    </div>

    <div class="app-form-actions">
      <%= f.submit "Save Allocation", class: "app-form-submit" %>
    </div>
  </div>
<% end %>
