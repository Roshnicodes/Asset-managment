<%= form_with(model: allocation, local: true) do |f| %>

  <div class="mb-3">
    <%= f.label :asset_id %>
    <%= f.number_field :asset_id, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :user_id %>
    <%= f.number_field :user_id, class: "form-control" %>
  </div>

  <div class="d-grid">
    <%= f.submit class: "btn btn-success" %>
  </div>

<% end %>