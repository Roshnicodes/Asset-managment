<%= form_with(model: approval_channel) do |form| %>
  <div class="app-form-card">
    <% if approval_channel.errors.any? %>
      <div class="app-form-errors">
        <h2><%= pluralize(approval_channel.errors.count, "error") %> found</h2>
        <ul>
          <% approval_channel.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>
    <p class="app-section-note">
      Configure dynamic approval flow using From User, To Responsible User, Previous Action, and Current Action.
      First step can keep Previous Action blank. Each next step should carry forward the previous Current Action.
    </p>

    <div class="app-form-grid two-col">
      <div class="app-form-field">
        <%= form.label :form_name, "Form Name" %>
        <%= form.select :form_name, @form_names, { prompt: "Select form name" }, class: "form-control", id: "approval_channel_form_name" %>
      </div>

      <div class="app-form-field">
        <%= form.label :theme_id, "Thematic Type" %>
        <%= form.collection_select :theme_id, @themes, :id, :name, { prompt: "Select thematic type" }, class: "form-control", id: "approval_channel_theme_id" %>
        <p class="form-text text-muted" style="font-size: 0.9rem;">Applicable mainly for Vendor Registration preferences.</p>
      </div>

      <div class="app-form-field">
        <%= form.label :stakeholder_category_id, "Stakeholder" %>
        <%= form.collection_select :stakeholder_category_id, StakeholderCategory.order(:name), :id, :name, { prompt: "Select stakeholder" }, class: "form-control" %>
      </div>
    </div>

    <script>
      document.addEventListener("DOMContentLoaded", function() {
        var formNameEl = document.getElementById("approval_channel_form_name");
        var themeEl = document.getElementById("approval_channel_theme_id");
        var themeContainer = themeEl.closest('.app-form-field');

        function toggleThemeField() {
          if (formNameEl.value === "Vendor Registration") {
            themeContainer.style.display = "block";
          } else {
            themeContainer.style.display = "none";
            themeEl.value = "";
          }
        }

        toggleThemeField();
        formNameEl.addEventListener("change", toggleThemeField);
      });
    </script>

    <%= form.hidden_field :approval_type, value: approval_channel.approval_type.presence || "Sequential" %>

    <div class="app-page-header" style="margin-top: 1rem;">
      <h3>Approval Channel Configuration</h3>
    </div>

    <div class="app-approval-channel-steps" data-approval-steps>
      <div class="app-approval-step-list" data-approval-step-list>
        <%= form.fields_for :approval_channel_steps do |step_form| %>
          <%= render "approval_step_fields", form: step_form, employee_options: @employee_options %>
        <% end %>
      </div>

      <template data-approval-step-template>
        <%= form.fields_for :approval_channel_steps, ApprovalChannelStep.new, child_index: "NEW_RECORD" do |step_form| %>
          <%= render "approval_step_fields", form: step_form, employee_options: @employee_options %>
        <% end %>
      </template>

      <div class="app-form-actions" style="justify-content: flex-start;">
        <button type="button" class="app-secondary-btn" data-add-approval-step>Add Step</button>
      </div>
    </div>

    <div class="app-form-actions">
      <%= form.submit "Save Approval Channel", class: "app-form-submit" %>
    </div>
  </div>
<% end %>
