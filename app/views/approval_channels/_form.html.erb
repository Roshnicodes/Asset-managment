<%= form_with(model: approval_channel) do |form| %>
  <div class="app-form-card">
    <% if approval_channel.errors.any? %>
      <div class="app-form-errors">
        <h2><%= pluralize(approval_channel.errors.count, "error") %> found</h2>
        <ul>
          <% approval_channel.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>
    <p class="app-section-note">
      Select only those employees whose email ID is saved in Employee Master. Their login is created automatically and approvals move one level at a time.
    </p>

    <div class="app-form-grid two-col">
      <div class="app-form-field">
        <%= form.label :form_name, "Form Name" %>
        <%= form.select :form_name, @form_names, { prompt: "Select form name" }, class: "form-control" %>
      </div>

      <div class="app-form-field">
        <%= form.label :approval_type, "Approval Type" %>
        <%= form.select :approval_type, @approval_types, { prompt: "Select approval type" }, class: "form-control" %>
      </div>

      <div class="app-form-field">
        <%= form.label :stakeholder_category_id, "Stakeholder" %>
        <%= form.collection_select :stakeholder_category_id, StakeholderCategory.order(:name), :id, :name, { prompt: "Select stakeholder" }, class: "form-control" %>
      </div>

      <div class="app-form-field">
        <%= form.label :level_1_approver, "Approval L1" %>
        <%= form.collection_select :level_1_employee_id, EmployeeMaster.order(:name), :id, :name, { prompt: "Select L1 employee" }, class: "form-control" %>
      </div>

      <div class="app-form-field">
        <%= form.label :level_2_approver, "Approval L2" %>
        <%= form.collection_select :level_2_employee_id, EmployeeMaster.order(:name), :id, :name, { prompt: "Select L2 employee" }, class: "form-control" %>
      </div>

      <div class="app-form-field">
        <%= form.label :level_3_approver, "Approval L3" %>
        <%= form.collection_select :level_3_employee_id, EmployeeMaster.order(:name), :id, :name, { prompt: "Select L3 employee" }, class: "form-control" %>
      </div>
    </div>

    <div class="app-form-actions">
      <%= form.submit "Save Approval Channel", class: "app-form-submit" %>
    </div>
  </div>
<% end %>
