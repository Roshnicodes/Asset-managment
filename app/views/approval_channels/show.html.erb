<div class="app-page-header">
  <h2>Approval Channel Details</h2>
  <%= link_to "Back", approval_channels_path, class: "app-back-link" %>
</div>

<%= render @approval_channel %>

<div class="app-detail-actions">
  <%= link_to "Edit", edit_approval_channel_path(@approval_channel), class: "app-secondary-btn" %>
  <%= button_to "Delete", @approval_channel, method: :delete, data: { turbo_confirm: "Delete this approval channel?" }, class: "app-danger-btn" %>
</div>
