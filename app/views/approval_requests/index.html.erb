<div class="app-toolbar">
  <div>
    <h1><%= @form_name.presence || "My Approvals" %></h1>
    <p class="app-section-note">Pending, approved, returned, rejected, or all requests for your login.</p>
  </div>
</div>

<div class="mb-3">
  <% %w[pending approved returned rejected all].each do |s| %>
    <%= link_to s.titleize, approval_requests_path(status: s, form_name: @form_name), class: "btn btn-sm me-2 #{'btn-primary' if @status == s} #{'btn-outline-primary' unless @status == s}" %>
  <% end %>
</div>

<% if @status == 'pending' || @status == 'all' %>
  <div class="app-page-header">
    <h2>Pending</h2>
  </div>

  <div class="app-table-wrap" style="margin-bottom: 1.5rem;">
    <table class="table app-table">
      <thead>
        <tr>
          <th>Form</th>
          <th>Reference</th>
          <th>Status</th>
          <th>Current Level</th>
          <th>Current Approver</th>
          <th>Current Action</th>
          <th>Approval Trail</th>
          <th>View</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <% @pending_approval_requests.each do |approval_request| %>
          <% current_step = approval_request.current_step %>
          <tr>
            <td><%= approval_request.form_name %></td>
            <td><%= approval_request.reference_label %></td>
            <td><%= approval_request.status_label %></td>
            <td>L<%= approval_request.current_level %></td>
            <td><%= approval_request.current_approver_label %></td>
            <td><%= current_step&.current_action_label || "-" %></td>
            <td><%= approval_request.approval_history_label %></td>
            <td>
              <% if approval_request.approvable.is_a?(VendorRegistration) %>
                <%= link_to "View", vendor_registration_path(approval_request.approvable), class: "app-action-button" %>
              <% elsif approval_request.approvable.is_a?(QuotationProposal) %>
                <%= link_to "View", quotation_proposal_path(approval_request.approvable), class: "app-action-button" %>
              <% else %>
                -
              <% end %>
            </td>
            <td>
              <div class="d-flex gap-2 flex-wrap">
                <%= render "approval_requests/approve_modal",
                  approval_request: approval_request,
                  modal_id: "approve-approval-request-#{approval_request.id}",
                  trigger_label: "Approve",
                  trigger_class: "app-form-submit" %>

                <%= render "approval_requests/return_modal",
                  approval_request: approval_request,
                  current_step: current_step,
                  modal_id: "return-approval-request-#{approval_request.id}",
                  trigger_label: "Return",
                  trigger_class: "app-secondary-btn" %>

                <%= render "approval_requests/reject_modal",
                  approval_request: approval_request,
                  modal_id: "reject-approval-request-#{approval_request.id}",
                  trigger_label: "Reject",
                  trigger_class: "app-danger-btn" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>

<% if @status.in?(%w[approved returned rejected all]) %>
  <div class="app-page-header">
    <h2>Processed</h2>
  </div>

  <div class="app-table-wrap">
    <table class="table app-table">
      <thead>
        <tr>
          <th>Form</th>
          <th>Reference</th>
          <th>Final Status</th>
          <th>Your Decision</th>
          <th>Remark</th>
          <th>Approval Trail</th>
          <th>View</th>
        </tr>
      </thead>
      <tbody>
        <% @processed_approval_requests.each do |approval_request| %>
          <% processed_steps = approval_request.approval_steps.reject { |item| item.status.in?(%w[waiting pending]) } %>
          <% step = if current_employee_master.present?
               processed_steps.find { |item| item.employee_master_id == current_employee_master.id }
             else
               processed_steps.max_by { |item| [item.actioned_at || Time.at(0), item.updated_at || Time.at(0)] }
             end %>
          <tr>
            <td><%= approval_request.form_name %></td>
            <td><%= approval_request.reference_label %></td>
            <td><%= approval_request.status_label %></td>
            <td><%= step&.effective_status_label || "-" %></td>
            <td><%= step&.remark.presence || "-" %></td>
            <td><%= approval_request.approval_history_label %></td>
            <td>
              <% if approval_request.approvable.is_a?(VendorRegistration) %>
                <%= link_to "View", vendor_registration_path(approval_request.approvable), class: "app-action-button" %>
              <% elsif approval_request.approvable.is_a?(QuotationProposal) %>
                <%= link_to "View", quotation_proposal_path(approval_request.approvable), class: "app-action-button" %>
              <% else %>
                -
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
