<%= form_with(model: asset, local: true) do |f| %>
  <div class="app-form-card">
    <% if asset.errors.any? %>
      <div class="app-form-errors">
        <h2><%= pluralize(asset.errors.count, "error") %> found</h2>
        <ul>
          <% asset.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="app-form-grid two-col">
      <div class="app-form-field">
        <%= f.label :product_id, "Product" %>
        <%= f.collection_select :product_id, Product.order(:name), :id, :name, { prompt: "Select product" }, class: "form-control" %>
      </div>

      <div class="app-form-field">
        <%= f.label :name, "Asset Name" %>
        <%= f.text_field :name, class: "form-control" %>
      </div>

      <div class="app-form-field">
        <%= f.label :serial_number, "Serial Number" %>
        <%= f.text_field :serial_number, class: "form-control", placeholder: "Enter serial number" %>
      </div>
    </div>

    <div class="app-form-actions">
      <%= f.submit "Save Asset", class: "app-form-submit" %>
    </div>
  </div>
<% end %>
