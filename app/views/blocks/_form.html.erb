<%= form_with(model: block) do |form| %>
  <div class="app-form-card">
    <div class="app-form-grid two-col">
      <div class="app-form-field">
        <%= form.label :district_id, "District" %>
        <%= form.collection_select :district_id, @districts, :id, :name, { prompt: "Select district" } %>
      </div>

      <div class="app-form-field">
        <%= form.label :name, "Block Name" %>
        <%= form.text_field :name, placeholder: "Enter block name" %>
      </div>
    </div>

    <div class="app-form-actions">
      <%= form.submit "Save Block", class: "app-form-submit" %>
    </div>
  </div>
<% end %>
