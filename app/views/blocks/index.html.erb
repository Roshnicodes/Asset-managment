<div class="app-toolbar">
  <div>
    <h1>LG - Blocks</h1>
    <p class="app-section-note">LG includes State, District, and Block.</p>
  </div>
  <%= link_to "Add Block", new_block_path, class: "app-primary-btn" %>
</div>

<div class="app-table-wrap">
  <table class="table app-table">
    <thead>
      <tr>
        <th>State</th>
        <th>District</th>
        <th>Block</th>
        <th>Action</th>
      </tr>
    </thead>
    <tbody>
      <% @blocks.each do |block| %>
        <tr>
          <td><%= block.district.state.name %></td>
          <td><%= block.district.name %></td>
          <td><%= block.name %></td>
          <td class="app-row-actions">
            <%= link_to "Edit", edit_block_path(block) %> |
            <%= link_to "Delete", block, method: :delete, data: { turbo_confirm: "Delete this block?" } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
