<div class="app-page-header">
  <h2>Block Details</h2>
  <%= link_to "Back", blocks_path, class: "app-back-link" %>
</div>

<%= render @block %>

<div class="app-detail-actions">
  <%= link_to "Edit", edit_block_path(@block), class: "app-secondary-btn" %>
  <%= button_to "Delete", @block, method: :delete, data: { turbo_confirm: "Delete this block?" }, class: "app-danger-btn" %>
</div>
