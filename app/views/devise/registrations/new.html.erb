<div class="auth-wrapper">
  <div class="auth-split-card">
    <%= render "devise/shared/auth_slider" %>
    
    <div class="auth-form-side">
      <div class="auth-header">
        <h1 class="auth-title">Sign Up</h1>
        <p class="auth-subtitle">Join us to manage your assets</p>
      </div>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "auth-form" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="form-group mb-4">
          <%= f.label :email, "Email Address", class: "form-label" %>
          <%= f.email_field :email, class: "form-control", placeholder: "yourname@example.com", autofocus: true %>
        </div>

        <div class="form-group mb-4">
          <%= f.label :password, "Set Password", class: "form-label" %>
          <%= f.password_field :password, class: "form-control", placeholder: "•••••••• (min 6 characters)" %>
        </div>

        <div class="form-group mb-4">
          <%= f.label :password_confirmation, "Confirm Password", class: "form-label" %>
          <%= f.password_field :password_confirmation, class: "form-control", placeholder: "••••••••" %>
        </div>

        <%= f.submit "CREATE ACCOUNT", class: "btn-auth-submit" %>
      <% end %>

      <div class="auth-footer text-center">
        <p>Already have an account? <%= link_to "Sign In", new_user_session_path %></p>
      </div>
    </div>
  </div>
</div>
