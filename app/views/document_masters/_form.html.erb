<%= form_with(model: document_master) do |form| %>
  <div class="app-form-card">
    <% if document_master.errors.any? %>
      <div class="app-form-errors">
        <h2><%= pluralize(document_master.errors.count, "error") %> found</h2>
        <ul>
          <% document_master.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="app-form-grid">
      <div class="app-form-field">
        <%= form.label :name, "Document Name" %>
        <%= form.text_field :name %>
      </div>

      <div class="app-form-field">
        <%= form.label :stakeholder_category_id, "Stakeholder" %>
        <%= form.collection_select :stakeholder_category_id, StakeholderCategory.order(:name), :id, :name, { prompt: "Select stakeholder" } %>
      </div>

      <div class="app-form-field">
        <%= form.label :firm_id, "Firm Type" %>
        <%= form.collection_select :firm_id, Firm.order(:name), :id, :name, { prompt: "All firm types" } %>
      </div>

      <div class="app-form-field">
        <%= form.label :mandatory, "Mandatory" %>
        <%= form.check_box :mandatory %>
      </div>

      <div class="app-form-field">
        <%= form.label :msme_only, "MSME Only" %>
        <%= form.check_box :msme_only %>
      </div>
    </div>

    <div class="app-form-actions">
      <%= form.submit "Save Document", class: "app-form-submit" %>
    </div>
  </div>
<% end %>
