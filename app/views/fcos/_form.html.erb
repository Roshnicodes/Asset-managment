<%= form_with model: @fco do |f| %>
  <div class="app-form-card">
    <div class="app-form-grid two-col">
      <div class="app-form-field">
        <%= f.label :pmu_id, "PMU" %>
        <%= f.select :pmu_id, options_for_select(@pmus.map { |pmu| ["#{pmu.state.name} / #{pmu.location_district.name} / #{pmu.block&.name || '-'} / #{pmu.name}", pmu.id] }, @fco.pmu_id), { prompt: "Select PMU" } %>
      </div>

      <div class="app-form-field">
        <%= f.label :name, "FCO Name" %>
        <%= f.text_field :name %>
      </div>
    </div>

    <div class="app-form-actions">
      <%= f.submit "Save FCO", class: "app-form-submit" %>
    </div>
  </div>
<% end %>
