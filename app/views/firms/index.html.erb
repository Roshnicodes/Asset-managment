<div class="app-toolbar">
  <h1>Firms</h1>
  <%= link_to "Add Firm", new_firm_path, class: "app-primary-btn" %>
</div>

<div class="app-table-wrap">
  <table class="table app-table">
    <thead>
      <tr>
        <th>Firm Name</th>
        <th>Action</th>
      </tr>
    </thead>
    <tbody>
      <% @firms.each do |firm| %>
        <tr>
          <td><%= firm.name %></td>
          <td class="app-row-actions">
            <%= link_to "Edit", edit_firm_path(firm) %> |
            <%= link_to "Delete", firm, method: :delete, data: { turbo_confirm: "Delete this firm?" } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
