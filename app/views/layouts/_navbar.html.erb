<nav class="navbar app-navbar px-4 py-2">
  <a class="app-brand" href="<%= root_path %>">
    <%= image_tag "asset-logo.png", alt: "ASA Logo", class: "app-logo-img" %>
  </a>

  <div class="ms-auto">
    <% if user_signed_in? %>
      <div class="d-inline-flex align-items-center me-3">
        <%= link_to notifications_path, class: "app-notification-link" do %>
          <%= app_icon(:approval, classes: "app-menu-icon") %>
          <% if unread_notifications_count.positive? %>
            <span class="app-notification-badge"><%= unread_notifications_count %></span>
          <% end %>
        <% end %>
      <div class="dropdown">
        <div class="app-profile-toggle" data-bs-toggle="dropdown" aria-expanded="false" style="cursor: pointer;">
          <div class="app-navbar-avatar-wrapper">
            <%= image_tag "user-avatar.png", class: "app-avatar-img", alt: "User Profile" %>
            <span class="avatar-chevron">▾</span>
          </div>
        </div>

        <ul class="dropdown-menu dropdown-menu-end app-profile-dropdown border-0 shadow-lg p-0">
          <li class="profile-dropdown-header bg-light bg-opacity-25 border-bottom p-3">
            <div class="d-flex align-items-center gap-3">
              <div class="header-avatar">
                <%= image_tag "user-avatar.png", class: "rounded-circle border", width: 44, height: 44 %>
              </div>
              <div class="lh-sm">
                <div class="fw-bold text-dark"><%= current_user.email.split('@').first.capitalize %></div>
                <div class="text-muted small"><%= current_user.email %></div>
              </div>
            </div>
          </li>
          <li class="py-1">
            <%= link_to profile_path, class: "dropdown-item d-flex align-items-center gap-2 py-2 px-3" do %>
              <%= app_icon(:people, classes: "icon-sm text-brand-mid") %>
              <span>Profile Settings</span>
            <% end %>
          </li>
          <li><hr class="dropdown-divider my-0 opacity-10"></li>
          <li class="py-1">
            <%= button_to destroy_user_session_path, method: :delete, class: "dropdown-item d-flex align-items-center gap-2 py-2 px-3 text-danger border-0 bg-transparent w-100 text-start" do %>
              <%= app_icon(:logout, classes: "icon-sm") %>
              <span>Logout Account</span>
            <% end %>
          </li>
        </ul>
      </div>
    <% end %>
  </div>
</nav>
