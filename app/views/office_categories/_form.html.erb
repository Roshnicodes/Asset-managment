<%= form_with(model: office_category) do |form| %>
  <div class="app-form-card">
    <div class="app-form-grid two-col">
      <div class="app-form-field">
        <%= form.label :name, "Category Name" %>
        <%= form.text_field :name, placeholder: "Enter office category name" %>
      </div>

      <div class="app-form-field">
        <%= form.label :office_level, "Office Level" %>
        <%= form.select :office_level, OfficeCategory::OFFICE_LEVELS, { prompt: "Select office level" } %>
      </div>

      <div class="app-form-field">
        <%= form.label :parent_id, "Parent Category" %>
        <%= form.collection_select :parent_id, @parent_categories.reject { |category| category.id == office_category.id }, :id, :name, { prompt: "Select parent category" } %>
      </div>
    </div>

    <div class="app-form-actions">
      <%= form.submit "Save Office Category", class: "app-form-submit" %>
    </div>
  </div>
<% end %>
