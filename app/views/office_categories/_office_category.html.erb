<div id="<%= dom_id office_category %>" class="app-detail-card">
  <div class="app-detail-grid">
    <div class="app-detail-item">
      <div class="app-detail-label">Category Name</div>
      <div class="app-detail-value"><%= office_category.name %></div>
    </div>

    <div class="app-detail-item">
      <div class="app-detail-label">Office Level</div>
      <div class="app-detail-value"><%= office_category.office_level %></div>
    </div>

    <div class="app-detail-item">
      <div class="app-detail-label">Parent Category</div>
      <div class="app-detail-value"><%= office_category.parent&.name || "None" %></div>
    </div>
  </div>
</div>
