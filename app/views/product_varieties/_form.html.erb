<%= form_with(model: product_variety) do |form| %>
  <div class="app-form-card">
    <% if product_variety.errors.any? %>
      <div class="app-form-errors">
        <h2><%= pluralize(product_variety.errors.count, "error") %> found</h2>
        <ul>
          <% product_variety.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="app-form-grid two-col">
      <div class="app-form-field">
        <%= form.label :product_id, "Product" %>
        <%= form.grouped_collection_select :product_id, @themes, :products, :name, :id, :name, { prompt: "Select product" }, class: "form-control" %>
      </div>

      <div class="app-form-field">
        <%= form.label :name, "Product Variety" %>
        <%= form.text_field :name, class: "form-control" %>
      </div>

      <div class="app-form-field">
        <%= form.label :stakeholder_category_id, "Stakeholder" %>
        <%= form.collection_select :stakeholder_category_id, StakeholderCategory.order(:name), :id, :name, { prompt: "Select stakeholder" }, class: "form-control" %>
      </div>
    </div>

    <div class="app-form-actions">
      <%= form.submit "Save Product Variety", class: "app-form-submit" %>
    </div>
  </div>
<% end %>
