<style>
  .sticky-top { position: sticky; top: 0; z-index: 100; }
  .app-table thead th { background: #f8fcf9 !important; border-bottom: 2px solid #eef3ef !important; }
  .app-table-wrap { max-height: calc(100vh - 250px); overflow-y: auto; overflow-x: auto; background: white; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); }
</style>

<div class="app-toolbar">
  <div class="d-flex align-items-center gap-3" style="width: 100%">
    <div>
      <h1 class="mb-0" style="white-space: nowrap;">Quotation Proposals</h1>
      <p class="app-section-note mb-0">Create drafts, submit them for approval, and monitor proposal workflow in one place.</p>
    </div>
    <div style="margin-left:auto; display:flex; gap:.5rem; align-items:center;">
      <% if can_view_menu?("quotation_proposal_form") %>
        <%= link_to "Create Quotation Proposal", new_quotation_proposal_path, class: "app-primary-btn" %>
      <% end %>
      <%= form_tag send_for_approval_quotation_proposals_path, method: :post, id: "send-quotation-approval-form", style: "display: inline;" do %>
        <button type="submit" class="app-secondary-btn d-none" id="send_quotation_for_approval_button">Send for Approval</button>
      <% end %>
    </div>
  </div>
</div>

<div class="app-table-wrap">
  <table class="table app-table">
    <thead class="sticky-top">
      <tr>
        <th><input type="checkbox" id="quotation_select_all_checkbox" style="cursor: pointer;"></th>
        <th>View</th>
        <th>Subject</th>
        <th>Theme</th>
        <th>Vendors</th>
        <th>End Date</th>
        <th>Items</th>
        <th>Approval Status</th>
        <th>Latest Remark</th>
        <th>Approval Trail</th>
        <th>Created By</th>
        <th>Action</th>
      </tr>
    </thead>
    <tbody>
      <% @quotation_proposals.each do |quotation_proposal| %>
        <tr>
          <td>
            <input type="checkbox" name="quotation_proposal_ids[]" value="<%= quotation_proposal.id %>" class="quotation-approval-checkbox" style="cursor: pointer;" form="send-quotation-approval-form">
          </td>
          <td>
            <%= link_to quotation_proposal_path(quotation_proposal), class: "app-action-icon text-primary", title: "View" do %>
              <%= app_icon(:eye, size: 18) %>
            <% end %>
          </td>
          <td><%= quotation_proposal.subject %></td>
          <td><%= quotation_proposal.theme.name %></td>
          <td><%= quotation_proposal.vendor_registrations.map(&:display_name).join(", ") %></td>
          <td><%= quotation_proposal.proposal_end_date.strftime("%d-%m-%Y") %></td>
          <td><%= quotation_proposal.quotation_proposal_items.size %></td>
          <td>
            <% status_class = case quotation_proposal.approval_request&.status
               when 'approved' then 'bg-success bg-opacity-10 text-success border-success'
               when 'rejected' then 'bg-danger bg-opacity-10 text-danger border-danger'
               when 'pending' then 'bg-info bg-opacity-10 text-info border-info'
               else 'bg-secondary bg-opacity-10 text-secondary border-secondary'
               end %>
            <span class="badge border <%= status_class %> fw-semibold px-2 py-1">
              <%= quotation_proposal.approval_request&.status_label || "Draft" %>
            </span>
          </td>
          <td><%= quotation_proposal.approval_request&.latest_remark.presence || "-" %></td>
          <td>
            <div class="d-flex flex-column gap-1" style="min-width: 250px;">
              <% if quotation_proposal.approval_request %>
                <% quotation_proposal.approval_request.approval_steps.each do |step| %>
                  <div class="d-flex align-items-center gap-2 small lh-sm">
                    <% dot_class = case step.effective_status
                       when 'approved' then 'text-success'
                       when 'rejected' then 'text-danger'
                       when 'pending' then 'text-info'
                       else 'text-muted opacity-50'
                       end %>
                    <span class="<%= dot_class %>" style="font-size: 1.2rem;">●</span>
                    <div class="text-truncate" style="max-width: 240px;">
                      <span class="fw-bold"><%= step.employee_master.name %></span>
                      <span class="text-muted opacity-75">(<%= step.current_action_label %>)</span>
                      <% if step.show_status_in_trail? %>
                        <span class="<%= dot_class %> fw-semibold">: <%= step.effective_status_label %></span>
                      <% end %>
                    </div>
                  </div>
                <% end %>
              <% else %>
                <span class="text-muted">-</span>
              <% end %>
            </div>
          </td>
          <td><%= quotation_proposal.user&.email || "-" %></td>
          <td class="app-row-actions">
            <div class="d-flex align-items-center gap-2">
              <% if quotation_proposal.approval_request.blank? %>
                <%= button_to "Send", send_for_approval_quotation_proposal_path(quotation_proposal), method: :post, class: "app-secondary-btn", title: "Send for Approval", form: { class: "d-inline-block" } %>
              <% end %>
              <%= link_to edit_quotation_proposal_path(quotation_proposal), class: "app-action-icon text-warning", title: "Edit" do %>
                <%= app_icon(:pencil, size: 18) %>
              <% end %>
              <%= button_to quotation_proposal_path(quotation_proposal), method: :delete, data: { turbo_confirm: "Delete this quotation proposal?" }, class: "app-action-icon text-danger", title: "Delete" do %>
                <%= app_icon(:trash, size: 18) %>
              <% end %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
