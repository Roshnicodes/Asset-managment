<%
  approval_request = @quotation_proposal.approval_request
  viewer_committee_steps = viewer_approval_steps_for(approval_request)
  user_pending_step = viewer_committee_steps.find { |step| step.status == "pending" }
  current_step = user_pending_step || approval_request&.current_step
  approver_view = approval_request.present? && user_pending_step.present? && approval_request.status == "pending"
  committee_approval_started = approval_request.present?
  owner_or_admin = current_user == @quotation_proposal.user || admin_user?
  editable_by_owner = approval_request.blank? || approval_request.employee_return_pending?
  committee_trail_steps = approval_request.present? ? approval_request.trail_steps : @quotation_proposal.committee_steps
  pending_approval_count = approval_request.present? ? approval_request.approval_steps.where(status: "pending").count : 0
  committee_scoring_allowed = @quotation_proposal.committee_member?(current_employee_master) || @quotation_proposal.committee_user?(current_user)
  workflow_class = case @quotation_proposal.workflow_status
                   when "vendor_selected" then "bg-success bg-opacity-10 text-success border-success"
                   when "responses_received" then "bg-primary bg-opacity-10 text-primary border-primary"
                   when "sent_to_vendors" then "bg-info bg-opacity-10 text-info border-info"
                   when "committee_approved" then "bg-success bg-opacity-10 text-success border-success"
                   when "rejected" then "bg-danger bg-opacity-10 text-danger border-danger"
                   when "returned" then "bg-danger bg-opacity-10 text-danger border-danger"
                   else "bg-warning bg-opacity-10 text-warning border-warning"
                   end
%>

<div class="app-page-header app-page-header-top">
  <div>
    <h2 class="app-page-title">Quotation Proposal Details</h2>
    <p class="app-page-subtitle"><%= @quotation_proposal.subject %></p>
  </div>
  <%= link_to "Back", quotation_proposals_path, class: "app-back-link" %>
</div>

<div class="app-detail-actions app-detail-actions-spread">
  <div class="d-flex align-items-center gap-2 flex-wrap">
    <span class="badge border <%= workflow_class %> fw-semibold px-3 py-2" style="font-size: 0.9rem;">
      <%= @quotation_proposal.workflow_status.humanize %>
    </span>

    <% viewer_committee_steps.each do |viewer_step| %>
      <span class="badge border <%= approval_status_css_class_for(viewer_step.effective_status) %> px-3 py-2" style="font-size: 0.9rem;">
        L<%= viewer_step.level %>: <%= viewer_step.effective_status_label %>
      </span>
    <% end %>

    <% if pending_approval_count.positive? %>
      <span class="badge border bg-light text-dark px-3 py-2" style="font-size: 0.9rem;">
        Pending Approvals: <%= pending_approval_count %>
      </span>
    <% end %>

    <span class="badge border bg-light text-dark px-3 py-2" style="font-size: 0.9rem;">
      Vendors: <%= @quotation_proposal.vendor_registrations.size %>
    </span>
  </div>

  <div class="d-flex align-items-center gap-2 flex-wrap">
    <% if owner_or_admin && (current_user == @quotation_proposal.user ? editable_by_owner : true) %>
      <%= link_to "Edit", edit_quotation_proposal_path(@quotation_proposal), class: "app-secondary-btn" %>
    <% end %>
    <% if owner_or_admin && @quotation_proposal.approval_request.blank? && @quotation_proposal.sent_to_vendors_at.blank? && !@quotation_proposal.committee_completed? %>
      <%= button_to "Start Committee Approval", send_for_approval_quotation_proposal_path(@quotation_proposal), method: :post, class: "app-secondary-btn" %>
    <% end %>
    <% if @quotation_proposal.committee_completed? && !@quotation_proposal.vendor_responses_received? %>
      <% send_button_label = @quotation_proposal.sent_to_vendors_at.present? ? "Resend To Vendor" : "Send To Vendor" %>
      <%= button_to send_button_label, send_to_vendors_quotation_proposal_path(@quotation_proposal), method: :post, class: "app-form-submit" %>
    <% end %>
  </div>
</div>

<% if approval_request&.employee_return_pending? %>
  <div class="app-form-card" style="margin-bottom: 2rem;">
    <div class="app-page-header app-subsection-header-tight">
      <div>
        <h3 style="margin-bottom: 0.35rem;">Returned To Employee</h3>
        <p class="app-section-note mb-0">Returned remark dekhkar quotation update karo. Save karte hi same approval chain phir se L1 se restart ho jayegi.</p>
      </div>
    </div>

    <div class="app-detail-grid">
      <div class="app-detail-item">
        <div class="app-detail-label">Returned By</div>
        <div class="app-detail-value"><%= approval_request.employee_return_actor_label %></div>
      </div>

      <div class="app-detail-item app-detail-item-full">
        <div class="app-detail-label">Return Remark</div>
        <div class="app-detail-value" style="white-space: pre-wrap;"><%= approval_request.employee_return_remark.presence || "No remark was added." %></div>
      </div>
    </div>
  </div>
<% end %>

<div class="app-detail-card">
  <div class="app-detail-grid">
    <div class="app-detail-item">
      <div class="app-detail-label">Subject</div>
      <div class="app-detail-value"><%= @quotation_proposal.subject %></div>
    </div>

    <div class="app-detail-item">
      <div class="app-detail-label">Theme</div>
      <div class="app-detail-value"><%= @quotation_proposal.theme.name %></div>
    </div>

    <div class="app-detail-item">
      <div class="app-detail-label">Proposal End Date</div>
      <div class="app-detail-value"><%= @quotation_proposal.proposal_end_date.strftime("%d-%m-%Y") %></div>
    </div>

    <div class="app-detail-item">
      <div class="app-detail-label">Workflow Status</div>
      <div class="app-detail-value"><%= @quotation_proposal.workflow_status.humanize %></div>
    </div>

    <div class="app-detail-item">
      <div class="app-detail-label">Sent To Vendor At</div>
      <div class="app-detail-value"><%= @quotation_proposal.sent_to_vendors_at&.strftime("%d-%m-%Y %H:%M") || "-" %></div>
    </div>

    <div class="app-detail-item">
      <div class="app-detail-label">Selected Vendor</div>
      <div class="app-detail-value"><%= @quotation_proposal.selected_vendor_registration&.display_name || "-" %></div>
    </div>

    <div class="app-detail-item app-detail-item-full">
      <div class="app-detail-label">Selected Vendors</div>
      <div class="app-detail-value">
        <div class="d-flex flex-wrap gap-2">
          <% @quotation_proposal.vendor_registrations.each do |vendor| %>
            <span class="badge border bg-light text-dark px-3 py-2" style="font-size: 0.9rem; font-weight: 500;">
              <%= vendor.display_name %>
            </span>
          <% end %>
        </div>
      </div>
    </div>

    <div class="app-detail-item app-detail-item-full">
      <div class="app-detail-label">Remark</div>
      <div class="app-detail-value"><%= @quotation_proposal.remark.presence || "-" %></div>
    </div>
  </div>
</div>

<div class="app-detail-card app-stack-gap-lg">
  <div class="app-page-header app-subsection-header-tight">
    <div>
      <h3 style="margin-bottom: 0.25rem;">Committee Approval Trail</h3>
      <p class="app-section-note mb-0">Start Committee Approval ke baad L1 se L4 sab members ko request ek saath milegi. Uske pehle ye sirf committee setup ke roop me rahega.</p>
    </div>
  </div>

  <div class="row g-3">
    <% committee_trail_steps.each do |step| %>
      <% step_status = if committee_approval_started
           step.respond_to?(:effective_status) ? step.effective_status : step.status
         else
           "waiting"
         end %>
      <% step_label = if committee_approval_started
           step.respond_to?(:effective_status_label) ? step.effective_status_label : step.status_label
         else
           "Not Started"
         end %>
      <% step_class = case step_status
         when "approved" then "border-success bg-success bg-opacity-10 text-success"
         when "returned" then "border-warning bg-warning bg-opacity-10 text-warning"
         when "rejected" then "border-danger bg-danger bg-opacity-10 text-danger"
         when "pending" then "border-info bg-info bg-opacity-10 text-info"
         else "border-secondary bg-light text-secondary"
         end %>
      <div class="col-md-6 col-xl-3">
        <div class="app-detail-item h-100 border <%= step_class %>">
          <div class="app-detail-label">L<%= step.level %></div>
          <div class="app-detail-value fw-semibold"><%= step.employee_master.name %></div>
          <div class="small text-muted mt-1"><%= step.employee_master.designation.presence || "Committee Member" %></div>
          <div class="mt-2"><strong>Status:</strong> <%= step_label %></div>
          <div class="mt-1"><strong>Time:</strong> <%= committee_approval_started ? (step.actioned_at&.strftime("%d-%m-%Y %H:%M") || "-") : "-" %></div>
          <div class="mt-1"><strong>Remark:</strong> <%= committee_approval_started ? (step.remark.presence || "-") : "-" %></div>
        </div>
      </div>
    <% end %>
  </div>
</div>

<% if approver_view %>
  <div class="app-form-card app-stack-gap-lg">
    <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
      <div>
        <h3 style="margin-bottom: 0.35rem;">Committee Action</h3>
        <p class="app-section-note mb-0">Committee approval start hone ke baad har pending member apne login se approve, return, ya reject kar sakta hai. Return seedha employee ko jayega aur resubmit par approval chain phir se ek saath sync ho jayegi.</p>
      </div>
      <span class="badge border bg-info bg-opacity-10 text-info px-3 py-2" style="font-size: 0.9rem;">
        Pending For You: L<%= current_step.level %>
      </span>
    </div>

    <div class="d-flex align-items-center gap-3 flex-wrap mt-3">
      <%= render "approval_requests/approve_modal",
        approval_request: approval_request,
        modal_id: "approve-approval-request-#{approval_request.id}",
        trigger_label: "Approve",
        trigger_class: "app-primary-btn px-4" %>

      <%= render "approval_requests/return_modal",
        approval_request: approval_request,
        current_step: user_pending_step,
        modal_id: "return-approval-request-#{approval_request.id}",
        trigger_label: "Return",
        trigger_class: "app-secondary-btn px-4" %>

      <%= render "approval_requests/reject_modal",
        approval_request: approval_request,
        modal_id: "reject-approval-request-#{approval_request.id}",
        trigger_label: "Reject",
        trigger_class: "app-danger-btn px-4" %>
    </div>
  </div>
<% end %>

<div class="app-page-header app-page-header-top app-page-header-center">
  <div>
    <h3 style="margin-bottom: 0.25rem;">Proposal Items</h3>
    <p class="app-section-note mb-0">Requested items and quantities for this quotation proposal.</p>
  </div>
  <span class="badge border bg-light text-dark px-3 py-2" style="font-size: 0.9rem;">
    Total Items: <%= @quotation_proposal.quotation_proposal_items.size %>
  </span>
</div>

<div class="app-table-wrap">
  <table class="table app-table">
    <thead>
      <tr>
        <th>Item Name</th>
        <th>Unit</th>
        <th>Quantity</th>
        <th>Remark</th>
      </tr>
    </thead>
    <tbody>
      <% @quotation_proposal.quotation_proposal_items.each do |item| %>
        <tr>
          <td><%= item.item_name %></td>
          <td><%= item.unit.name %></td>
          <td><%= item.quantity %></td>
          <td><%= item.remark.presence || "-" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<% if @quotation_proposal.vendor_responses_received? %>
  <% @quotation_proposal.recalculate_vendor_rankings! %>
  <div class="app-detail-card app-stack-gap-lg">
    <div class="app-page-header app-subsection-header-tight">
      <div>
        <h3 style="margin-bottom: 0.25rem;">Committee Comparison</h3>
        <p class="app-section-note mb-0">Committee vendor responses compare karke score degi. Higher score aur better comparison ke basis par vendor select kiya ja sakta hai.</p>
      </div>
      <span class="badge border bg-light text-dark px-3 py-2" style="font-size: 0.9rem;">
        <%= committee_scoring_allowed ? "Committee scoring access" : "View only" %>
      </span>
    </div>

    <% comparison_vendors = @quotation_proposal.quotation_proposal_vendors.includes(vendor_registration: [], vendor_items: { quotation_proposal_item: :unit }) %>
    <% responded_vendors = comparison_vendors.select(&:response_submitted?) %>
    <% lowest_amount_vendor_id = responded_vendors.min_by { |vendor| vendor.total_quoted_amount.to_d }&.id %>
    <% lowest_grand_total_vendor_id = responded_vendors.min_by { |vendor| vendor.grand_total_amount.to_d }&.id %>
    <% top_rank_vendor_id = responded_vendors.find { |vendor| vendor.rank_position == 1 }&.id %>
    <%= form_with url: score_vendors_quotation_proposal_path(@quotation_proposal), method: :patch, local: true do %>
      <div class="app-table-wrap" style="overflow-x: auto; overflow-y: visible;">
        <table class="table app-table" style="min-width: <%= 320 + (comparison_vendors.size * 280) %>px;">
        <thead>
          <tr>
            <th style="min-width: 240px; position: sticky; left: 0; z-index: 3; background: #f7fbf8; box-shadow: 8px 0 18px rgba(26, 58, 42, 0.04);">Compare Field</th>
            <% comparison_vendors.each do |proposal_vendor| %>
              <% header_style = if proposal_vendor.selected?
                "background: linear-gradient(180deg, #effaf3 0%, #ffffff 100%); border-bottom: 2px solid #198754;"
              elsif proposal_vendor.id == top_rank_vendor_id
                "background: linear-gradient(180deg, #fff8e8 0%, #ffffff 100%); border-bottom: 2px solid #f0ad00;"
              else
                "background: linear-gradient(180deg, #f8fbff 0%, #ffffff 100%);"
              end %>
              <th style="min-width: 280px; vertical-align: top; <%= header_style %>">
                <div style="display: flex; flex-direction: column; gap: 0.45rem;">
                  <div class="fw-semibold" style="font-size: 1rem;"><%= proposal_vendor.vendor_registration.display_name %></div>
                  <div class="small text-muted"><%= proposal_vendor.response_status.humanize %></div>
                  <div class="d-flex gap-2 flex-wrap">
                    <% if proposal_vendor.selected? %>
                      <span class="badge border bg-success bg-opacity-10 text-success">Selected</span>
                    <% end %>
                    <% if proposal_vendor.id == top_rank_vendor_id %>
                      <span class="badge border bg-warning bg-opacity-10 text-warning">Top Rank</span>
                    <% end %>
                    <% if proposal_vendor.id == lowest_grand_total_vendor_id %>
                      <span class="badge border bg-primary bg-opacity-10 text-primary">Best Price</span>
                    <% end %>
                  </div>
                </div>
              </th>
            <% end %>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td style="position: sticky; left: 0; z-index: 2; background: #fdfefe; box-shadow: 8px 0 18px rgba(26, 58, 42, 0.03);"><strong>Committee Score</strong></td>
            <% comparison_vendors.each do |proposal_vendor| %>
              <td>
                <% if proposal_vendor.response_submitted? %>
                  <% if committee_scoring_allowed %>
                    <div class="d-flex gap-2 align-items-center flex-wrap">
                      <%= number_field_tag "committee_scores[#{proposal_vendor.id}]", proposal_vendor.committee_score, min: 0, placeholder: "Enter score", class: "form-control", style: "max-width: 130px;" %>
                    </div>
                  <% else %>
                    <span class="text-muted">Committee members can update score</span>
                  <% end %>
                  <div class="small text-muted mt-2">
                    Saved score: <strong><%= proposal_vendor.committee_score.present? ? proposal_vendor.committee_score : "Not scored yet" %></strong>
                  </div>
                <% else %>
                  <span class="text-muted">Awaiting vendor response</span>
                <% end %>
              </td>
            <% end %>
          </tr>
          <% if committee_scoring_allowed %>
            <tr>
              <td style="position: sticky; left: 0; z-index: 2; background: #fdfefe; box-shadow: 8px 0 18px rgba(26, 58, 42, 0.03);"><strong>Save Scores</strong></td>
              <td colspan="<%= comparison_vendors.size %>">
                <div class="d-flex justify-content-end">
                  <%= submit_tag "Save All Committee Scores", class: "app-form-submit" %>
                </div>
              </td>
            </tr>
          <% end %>
          <tr>
            <td style="position: sticky; left: 0; z-index: 2; background: #fdfefe; box-shadow: 8px 0 18px rgba(26, 58, 42, 0.03);"><strong>Rank</strong></td>
            <% comparison_vendors.each do |proposal_vendor| %>
              <td style="<%= 'background: #fff8e8;' if proposal_vendor.id == top_rank_vendor_id %>">
                <%= proposal_vendor.rank_position || "-" %>
              </td>
            <% end %>
          </tr>
          <tr>
            <td style="position: sticky; left: 0; z-index: 2; background: #fdfefe; box-shadow: 8px 0 18px rgba(26, 58, 42, 0.03);"><strong>Selected</strong></td>
            <% comparison_vendors.each do |proposal_vendor| %>
              <td style="<%= 'background: #effaf3;' if proposal_vendor.selected? %>"><%= proposal_vendor.selected? ? "Yes" : "No" %></td>
            <% end %>
          </tr>
          <tr>
            <td style="position: sticky; left: 0; z-index: 2; background: #fdfefe; box-shadow: 8px 0 18px rgba(26, 58, 42, 0.03);"><strong>Amount Total</strong></td>
            <% comparison_vendors.each do |proposal_vendor| %>
              <td style="<%= 'background: #f5fbf7;' if proposal_vendor.id == lowest_amount_vendor_id %>">
                <%= number_with_precision(proposal_vendor.total_quoted_amount, precision: 2) %>
              </td>
            <% end %>
          </tr>
          <tr>
            <td style="position: sticky; left: 0; z-index: 2; background: #fdfefe; box-shadow: 8px 0 18px rgba(26, 58, 42, 0.03);"><strong>Grand Total</strong></td>
            <% comparison_vendors.each do |proposal_vendor| %>
              <td style="<%= 'background: #eef8ff;' if proposal_vendor.id == lowest_grand_total_vendor_id %>">
                <%= number_with_precision(proposal_vendor.grand_total_amount, precision: 2) %>
              </td>
            <% end %>
          </tr>
          <tr>
            <td style="position: sticky; left: 0; z-index: 2; background: #fdfefe; box-shadow: 8px 0 18px rgba(26, 58, 42, 0.03);"><strong>Selection Status</strong></td>
            <% comparison_vendors.each do |proposal_vendor| %>
              <td>
                <% if proposal_vendor.rank_position == 1 && proposal_vendor.committee_score.present? %>
                  <span class="badge border bg-success bg-opacity-10 text-success">Auto selected by top rank</span>
                <% elsif proposal_vendor.response_submitted? && proposal_vendor.committee_score.present? %>
                  <span class="text-muted">Selection follows rank order</span>
                <% else %>
                  <span class="text-muted">Selection pending score</span>
                <% end %>
              </td>
            <% end %>
          </tr>
          <% @quotation_proposal.quotation_proposal_items.includes(:unit).each do |proposal_item| %>
            <tr>
              <td style="position: sticky; left: 0; z-index: 2; background: #fdfefe; box-shadow: 8px 0 18px rgba(26, 58, 42, 0.03);">
                <strong><%= proposal_item.item_name %></strong>
                <div class="small text-muted mt-1">
                  Qty: <%= proposal_item.quantity %> <%= proposal_item.unit.name %>
                </div>
                <div class="small text-muted">
                  Proposal Remark: <%= proposal_item.remark.presence || "-" %>
                </div>
              </td>
              <% comparison_vendors.each do |proposal_vendor| %>
                <% vendor_item = proposal_vendor.vendor_items.find { |item| item.quotation_proposal_item_id == proposal_item.id } %>
                <td style="<%= 'background: #fbfff7;' if proposal_vendor.selected? %>">
                  <div><strong>Rate:</strong> <%= vendor_item&.quoted_rate.present? ? number_with_precision(vendor_item.quoted_rate, precision: 2) : "-" %></div>
                  <div class="mt-1"><strong>Amount:</strong> <%= vendor_item&.line_total.present? ? number_with_precision(vendor_item.line_total, precision: 2) : "-" %></div>
                  <div class="mt-1"><strong>GST %:</strong> <%= vendor_item&.gst_percentage.present? ? number_with_precision(vendor_item.gst_percentage, precision: 2) : "-" %></div>
                  <div class="mt-1"><strong>Grand Total:</strong> <%= vendor_item&.grand_total.present? ? number_with_precision(vendor_item.grand_total, precision: 2) : "-" %></div>
                  <div class="mt-1"><strong>Remark:</strong> <%= vendor_item&.remark.presence || "-" %></div>
                </td>
              <% end %>
            </tr>
          <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  </div>
<% end %>
