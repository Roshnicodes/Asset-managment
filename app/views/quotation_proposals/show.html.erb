<%
  current_committee_step = @quotation_proposal.current_committee_step
  my_pending_committee_step = @quotation_proposal.committee_steps.find_by(employee_master_id: current_employee_master&.id, status: "pending")
  committee_action_allowed = my_pending_committee_step.present?
  workflow_class = case @quotation_proposal.workflow_status
                   when "vendor_selected" then "bg-success bg-opacity-10 text-success border-success"
                   when "responses_received" then "bg-primary bg-opacity-10 text-primary border-primary"
                   when "sent_to_vendors" then "bg-info bg-opacity-10 text-info border-info"
                   when "committee_approved" then "bg-success bg-opacity-10 text-success border-success"
                   when "returned" then "bg-danger bg-opacity-10 text-danger border-danger"
                   else "bg-warning bg-opacity-10 text-warning border-warning"
                   end
%>

<div class="app-page-header" style="display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; margin-bottom: 1.5rem;">
  <div>
    <h2 style="margin: 0; font-size: 1.8rem; color: #1a3a2a;">Quotation Proposal Details</h2>
    <p style="margin: 0.5rem 0 0 0; color: #6b8e7f; font-size: 0.95rem;"><%= @quotation_proposal.subject %></p>
  </div>
  <%= link_to "Back", quotation_proposals_path, class: "app-back-link" %>
</div>

<div class="app-detail-actions" style="justify-content: space-between; align-items: center; flex-wrap: wrap; margin-bottom: 1.25rem;">
  <div class="d-flex align-items-center gap-2 flex-wrap">
    <span class="badge border <%= workflow_class %> fw-semibold px-3 py-2" style="font-size: 0.9rem;">
      <%= @quotation_proposal.workflow_status.humanize %>
    </span>

    <% if current_committee_step.present? %>
      <span class="badge border bg-light text-dark px-3 py-2" style="font-size: 0.9rem;">
        Pending Approvals: <%= @quotation_proposal.committee_steps.where(status: "pending").count %>
      </span>
    <% end %>

    <span class="badge border bg-light text-dark px-3 py-2" style="font-size: 0.9rem;">
      Vendors: <%= @quotation_proposal.vendor_registrations.size %>
    </span>
  </div>

  <div class="d-flex align-items-center gap-2 flex-wrap">
    <%= link_to "Edit", edit_quotation_proposal_path(@quotation_proposal), class: "app-secondary-btn" %>
    <% if @quotation_proposal.sent_to_vendors_at.blank? && !@quotation_proposal.committee_completed? %>
      <%= button_to "Start Committee Approval", send_for_approval_quotation_proposal_path(@quotation_proposal), method: :post, class: "app-secondary-btn" %>
    <% end %>
    <% if @quotation_proposal.committee_completed? && @quotation_proposal.sent_to_vendors_at.blank? %>
      <%= button_to "Send To Vendor", send_to_vendors_quotation_proposal_path(@quotation_proposal), method: :post, class: "app-form-submit" %>
    <% end %>
  </div>
</div>

<div class="app-detail-card">
  <div class="app-detail-grid">
    <div class="app-detail-item">
      <div class="app-detail-label">Subject</div>
      <div class="app-detail-value"><%= @quotation_proposal.subject %></div>
    </div>

    <div class="app-detail-item">
      <div class="app-detail-label">Theme</div>
      <div class="app-detail-value"><%= @quotation_proposal.theme.name %></div>
    </div>

    <div class="app-detail-item">
      <div class="app-detail-label">Proposal End Date</div>
      <div class="app-detail-value"><%= @quotation_proposal.proposal_end_date.strftime("%d-%m-%Y") %></div>
    </div>

    <div class="app-detail-item">
      <div class="app-detail-label">Workflow Status</div>
      <div class="app-detail-value"><%= @quotation_proposal.workflow_status.humanize %></div>
    </div>

    <div class="app-detail-item">
      <div class="app-detail-label">Sent To Vendor At</div>
      <div class="app-detail-value"><%= @quotation_proposal.sent_to_vendors_at&.strftime("%d-%m-%Y %H:%M") || "-" %></div>
    </div>

    <div class="app-detail-item">
      <div class="app-detail-label">Selected Vendor</div>
      <div class="app-detail-value"><%= @quotation_proposal.selected_vendor_registration&.display_name || "-" %></div>
    </div>

    <div class="app-detail-item" style="grid-column: 1 / -1;">
      <div class="app-detail-label">Selected Vendors</div>
      <div class="app-detail-value">
        <div class="d-flex flex-wrap gap-2">
          <% @quotation_proposal.vendor_registrations.each do |vendor| %>
            <span class="badge border bg-light text-dark px-3 py-2" style="font-size: 0.9rem; font-weight: 500;">
              <%= vendor.display_name %>
            </span>
          <% end %>
        </div>
      </div>
    </div>

    <div class="app-detail-item" style="grid-column: 1 / -1;">
      <div class="app-detail-label">Remark</div>
      <div class="app-detail-value"><%= @quotation_proposal.remark.presence || "-" %></div>
    </div>
  </div>
</div>

<div class="app-detail-card" style="margin-top: 1.5rem;">
  <div class="app-page-header" style="margin-bottom: 1rem;">
    <div>
      <h3 style="margin-bottom: 0.25rem;">Committee Approval Trail</h3>
      <p class="app-section-note mb-0">L1 se L4 tak sab approvals yahin visible rahenge. Sab approve hone ke baad hi vendors ko quotation bheja jayega.</p>
    </div>
  </div>

  <div class="row g-3">
    <% @quotation_proposal.committee_steps.each do |step| %>
      <% step_class = case step.status
         when "approved" then "border-success bg-success bg-opacity-10 text-success"
         when "returned" then "border-danger bg-danger bg-opacity-10 text-danger"
         else "border-warning bg-warning bg-opacity-10 text-warning"
         end %>
      <div class="col-md-6 col-xl-3">
        <div class="app-detail-item h-100 border <%= step_class %>">
          <div class="app-detail-label">L<%= step.level %></div>
          <div class="app-detail-value fw-semibold"><%= step.employee_master.name %></div>
          <div class="small text-muted mt-1"><%= step.employee_master.designation.presence || "Committee Member" %></div>
          <div class="mt-2"><strong>Status:</strong> <%= step.status_label %></div>
          <div class="mt-1"><strong>Time:</strong> <%= step.actioned_at&.strftime("%d-%m-%Y %H:%M") || "-" %></div>
          <div class="mt-1"><strong>Remark:</strong> <%= step.remark.presence || "-" %></div>
        </div>
      </div>
    <% end %>
  </div>
</div>

<% if committee_action_allowed %>
  <div class="app-form-card" style="margin-top: 1.5rem;">
    <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
      <div>
        <h3 style="margin-bottom: 0.35rem;">Committee Action</h3>
        <p class="app-section-note mb-0">Aapka committee approval pending hai. Yahin se approve ya return kar sakte ho.</p>
      </div>
      <span class="badge border bg-warning bg-opacity-10 text-warning px-3 py-2" style="font-size: 0.9rem;">
        L<%= my_pending_committee_step.level %> Approval
      </span>
    </div>

    <div class="row g-3 mt-1">
      <div class="col-lg-6">
        <%= form_with url: approve_committee_quotation_proposal_path(@quotation_proposal), method: :patch, local: true do |form| %>
          <div class="app-detail-item h-100">
            <div class="app-detail-label">Approve Remark</div>
            <%= form.text_area :remark, placeholder: "Optional remark", class: "form-control", style: "min-height: 120px;" %>
            <div class="mt-3">
              <%= form.submit "Approve", class: "app-primary-btn px-4" %>
            </div>
          </div>
        <% end %>
      </div>

      <div class="col-lg-6">
        <%= form_with url: return_committee_quotation_proposal_path(@quotation_proposal), method: :patch, local: true do |form| %>
          <div class="app-detail-item h-100">
            <div class="app-detail-label">Return Remark</div>
            <%= form.text_area :remark, placeholder: "Return remark (required)", class: "form-control", style: "min-height: 120px;", required: true %>
            <div class="mt-3">
              <%= form.submit "Return", class: "app-danger-btn px-4" %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>

<div class="app-page-header" style="margin-top: 1.5rem; display: flex; justify-content: space-between; align-items: center; gap: 1rem;">
  <div>
    <h3 style="margin-bottom: 0.25rem;">Proposal Items</h3>
    <p class="app-section-note mb-0">Requested items and quantities for this quotation proposal.</p>
  </div>
  <span class="badge border bg-light text-dark px-3 py-2" style="font-size: 0.9rem;">
    Total Items: <%= @quotation_proposal.quotation_proposal_items.size %>
  </span>
</div>

<div class="app-table-wrap">
  <table class="table app-table">
    <thead>
      <tr>
        <th>Item Name</th>
        <th>Unit</th>
        <th>Quantity</th>
        <th>Remark</th>
      </tr>
    </thead>
    <tbody>
      <% @quotation_proposal.quotation_proposal_items.each do |item| %>
        <tr>
          <td><%= item.item_name %></td>
          <td><%= item.unit.name %></td>
          <td><%= item.quantity %></td>
          <td><%= item.remark.presence || "-" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<% if @quotation_proposal.vendor_responses_received? %>
  <% @quotation_proposal.recalculate_vendor_rankings! %>
  <div class="app-detail-card" style="margin-top: 1.5rem;">
    <div class="app-page-header" style="margin-bottom: 1rem;">
      <div>
        <h3 style="margin-bottom: 0.25rem;">Committee Comparison</h3>
        <p class="app-section-note mb-0">Committee vendor responses compare karke score degi. Higher score aur better comparison ke basis par vendor select kiya ja sakta hai.</p>
      </div>
    </div>

    <div class="app-table-wrap">
      <table class="table app-table">
        <thead>
          <tr>
            <th>Vendor</th>
            <th>Status</th>
            <th>Total Quote</th>
            <th>Committee Score</th>
            <th>Rank</th>
            <th>Selected</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% @quotation_proposal.quotation_proposal_vendors.includes(:vendor_registration, :vendor_items).each do |proposal_vendor| %>
            <tr>
              <td><%= proposal_vendor.vendor_registration.display_name %></td>
              <td><%= proposal_vendor.response_status.humanize %></td>
              <td><%= number_with_precision(proposal_vendor.total_quoted_amount, precision: 2) %></td>
              <td>
                <%= form_with url: score_vendor_quotation_proposal_path(@quotation_proposal, proposal_vendor_id: proposal_vendor.id), method: :patch, local: true, class: "d-flex gap-2 align-items-center" do |form| %>
                  <%= form.number_field :committee_score, value: proposal_vendor.committee_score, min: 0, class: "form-control", style: "max-width: 110px;" %>
                  <%= form.submit "Save", class: "app-secondary-btn" %>
                <% end %>
              </td>
              <td><%= proposal_vendor.rank_position || "-" %></td>
              <td><%= proposal_vendor.selected? ? "Yes" : "No" %></td>
              <td>
                <%= button_to "Select Vendor", select_vendor_quotation_proposal_path(@quotation_proposal, proposal_vendor_id: proposal_vendor.id), method: :patch, class: "app-form-submit" %>
              </td>
            </tr>
            <% if proposal_vendor.vendor_items.any? %>
              <tr>
                <td colspan="7" style="background: #fbfdfb;">
                  <strong>Item-wise Comparison</strong>
                  <div class="app-table-wrap" style="margin-top: 0.75rem;">
                    <table class="table app-table">
                      <thead>
                        <tr>
                          <th>Item</th>
                          <th>Qty</th>
                          <th>Unit</th>
                          <th>Rate</th>
                          <th>Line Total</th>
                          <th>Remark</th>
                        </tr>
                      </thead>
                      <tbody>
                        <% proposal_vendor.vendor_items.includes(quotation_proposal_item: :unit).each do |vendor_item| %>
                          <tr>
                            <td><%= vendor_item.quotation_proposal_item.item_name %></td>
                            <td><%= vendor_item.quotation_proposal_item.quantity %></td>
                            <td><%= vendor_item.quotation_proposal_item.unit.name %></td>
                            <td><%= vendor_item.quoted_rate.present? ? number_with_precision(vendor_item.quoted_rate, precision: 2) : "-" %></td>
                            <td><%= vendor_item.line_total.present? ? number_with_precision(vendor_item.line_total, precision: 2) : "-" %></td>
                            <td><%= vendor_item.remark.presence || "-" %></td>
                          </tr>
                        <% end %>
                      </tbody>
                    </table>
                  </div>
                </td>
              </tr>
            <% end %>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% end %>
