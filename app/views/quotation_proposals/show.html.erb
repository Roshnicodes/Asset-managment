<% approval_request = @quotation_proposal.approval_request %>
<% current_step = approval_request&.current_step %>
<% approver_view = approval_request.present? && current_step&.employee_master_id == current_employee_master&.id && approval_request.status == "pending" %>
<% status_class = case approval_request&.status
   when "approved" then "bg-success bg-opacity-10 text-success border-success"
   when "rejected" then "bg-danger bg-opacity-10 text-danger border-danger"
   when "pending" then "bg-info bg-opacity-10 text-info border-info"
   else "bg-secondary bg-opacity-10 text-secondary border-secondary"
   end %>

<div class="app-page-header" style="display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; margin-bottom: 1.5rem;">
  <div>
    <h2 style="margin: 0; font-size: 1.8rem; color: #1a3a2a;">Quotation Proposal Details</h2>
    <p style="margin: 0.5rem 0 0 0; color: #6b8e7f; font-size: 0.95rem;"><%= @quotation_proposal.subject %></p>
  </div>
  <%= link_to "Back", (can_view_menu?("quotation_proposal_form") ? quotation_proposals_path : list_quotation_proposals_path), class: "app-back-link" %>
</div>

<div class="app-detail-actions" style="justify-content: space-between; align-items: center; flex-wrap: wrap; margin-bottom: 1.25rem;">
  <div class="d-flex align-items-center gap-2 flex-wrap">
    <span class="badge border <%= status_class %> fw-semibold px-3 py-2" style="font-size: 0.9rem;">
      <%= approval_request&.status_label || "Draft" %>
    </span>

    <% if current_step.present? %>
      <span class="badge border bg-info bg-opacity-10 text-info px-3 py-2" style="font-size: 0.9rem;">
        Current Approver: <%= current_step.employee_master.name %>
        <small>(<%= current_step.current_action_label %>)</small>
      </span>
    <% end %>

    <span class="badge border bg-light text-dark px-3 py-2" style="font-size: 0.9rem;">
      Items: <%= @quotation_proposal.quotation_proposal_items.size %>
    </span>
  </div>

  <div class="d-flex align-items-center gap-2 flex-wrap">
    <% if can_view_menu?("quotation_proposal_form") %>
      <%= link_to "Edit", edit_quotation_proposal_path(@quotation_proposal), class: "app-secondary-btn" %>
    <% end %>
    <% if can_view_menu?("quotation_proposal_form") && approval_request.blank? %>
      <%= button_to "Send for Approval", send_for_approval_quotation_proposal_path(@quotation_proposal), method: :post, class: "app-form-submit" %>
    <% end %>
  </div>
</div>

<div class="app-detail-card">
  <div class="app-detail-grid">
    <div class="app-detail-item">
      <div class="app-detail-label">Subject</div>
      <div class="app-detail-value"><%= @quotation_proposal.subject %></div>
    </div>

    <div class="app-detail-item">
      <div class="app-detail-label">Theme</div>
      <div class="app-detail-value"><%= @quotation_proposal.theme.name %></div>
    </div>

    <div class="app-detail-item">
      <div class="app-detail-label">Proposal End Date</div>
      <div class="app-detail-value"><%= @quotation_proposal.proposal_end_date.strftime("%d-%m-%Y") %></div>
    </div>

    <div class="app-detail-item">
      <div class="app-detail-label">Approval Status</div>
      <div class="app-detail-value">
        <span class="badge border <%= status_class %> fw-semibold px-3 py-2" style="font-size: 0.9rem;">
          <%= approval_request&.status_label || "Draft" %>
        </span>
      </div>
    </div>

    <div class="app-detail-item">
      <div class="app-detail-label">Latest Remark</div>
      <div class="app-detail-value"><%= approval_request&.latest_remark.presence || "-" %></div>
    </div>

    <div class="app-detail-item">
      <div class="app-detail-label">Current Stage</div>
      <div class="app-detail-value">
        <% if current_step.present? %>
          <span class="fw-semibold"><%= current_step.current_action_label %></span>
          <div class="text-muted small mt-1"><%= current_step.employee_master.name %></div>
        <% else %>
          Completed
        <% end %>
      </div>
    </div>

    <div class="app-detail-item" style="grid-column: 1 / -1;">
      <div class="app-detail-label">Selected Vendors</div>
      <div class="app-detail-value">
        <div class="d-flex flex-wrap gap-2">
          <% @quotation_proposal.vendor_registrations.each do |vendor| %>
            <span class="badge border bg-light text-dark px-3 py-2" style="font-size: 0.9rem; font-weight: 500;">
              <%= vendor.display_name %>
            </span>
          <% end %>
        </div>
      </div>
    </div>

    <div class="app-detail-item" style="grid-column: 1 / -1;">
      <div class="app-detail-label">Remark</div>
      <div class="app-detail-value"><%= @quotation_proposal.remark.presence || "-" %></div>
    </div>

    <div class="app-detail-item" style="grid-column: 1 / -1;">
      <div class="app-detail-label">Approval Trail</div>
      <div class="app-detail-value">
        <% if approval_request.present? %>
          <div class="d-flex flex-wrap gap-2 mt-2">
            <% approval_request.approval_steps.each do |step| %>
              <% step_class = case step.effective_status
                 when "approved" then "border-success bg-success bg-opacity-10 text-success"
                 when "rejected" then "border-danger bg-danger bg-opacity-10 text-danger"
                 when "pending" then "border-info bg-info bg-opacity-10 text-info"
                 else "border-secondary bg-light text-muted opacity-50"
                 end %>
              <div class="badge border <%= step_class %> px-3 py-2 text-start d-flex flex-column gap-1" style="font-style: normal; font-weight: normal; font-size: 0.85rem; line-height: 1.2;">
                <span class="fw-bold border-bottom pb-1 mb-1">Step <%= step.level %>: <%= step.employee_master.name %></span>
                <span>
                  <%= step.current_action_label %>
                  <% if step.show_status_in_trail? %>
                    : <strong><%= step.effective_status_label %></strong>
                  <% end %>
                </span>
                <% if step.actioned_at.present? %>
                  <span class="small opacity-75"><%= step.actioned_at.strftime("%d-%m-%Y %H:%M") %></span>
                <% end %>
              </div>
            <% end %>
          </div>
        <% else %>
          -
        <% end %>
      </div>
    </div>
  </div>
</div>

<% if approver_view %>
  <div class="app-form-card" style="margin-top: 1.5rem;">
    <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
      <div>
        <h3 style="margin-bottom: 0.35rem;">Pending Approval Action</h3>
        <p class="app-section-note mb-0">Approve bina remark ke bhi ho sakta hai. Return ke liye remark required hai.</p>
      </div>
      <span class="badge border bg-warning bg-opacity-10 text-warning px-3 py-2" style="font-size: 0.9rem;">
        <%= current_step.current_action_label %>
      </span>
    </div>

    <div class="row g-3 mt-1">
      <div class="col-lg-6">
        <%= form_with url: approve_approval_request_path(approval_request), method: :patch, local: true do |form| %>
          <div class="app-detail-item h-100">
            <div class="app-detail-label">Approve Remark</div>
            <%= form.text_area :remark, placeholder: "Optional remark", class: "form-control", style: "min-height: 120px;" %>
            <div class="mt-3">
              <%= form.submit "Approve", class: "app-primary-btn px-4" %>
            </div>
          </div>
        <% end %>
      </div>

      <div class="col-lg-6">
        <%= form_with url: reject_approval_request_path(approval_request), method: :patch, local: true do |form| %>
          <div class="app-detail-item h-100">
            <div class="app-detail-label">Return Remark</div>
            <%= form.text_area :remark, placeholder: "Return remark (required)", class: "form-control", style: "min-height: 120px;", required: true %>
            <div class="mt-3">
              <%= form.submit "Return", class: "app-danger-btn px-4" %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>

<% if approval_request.present? %>
  <div class="app-detail-card app-approval-timeline-card">
    <div class="app-page-header">
      <h3>Approval Timeline</h3>
    </div>

    <div class="app-approval-timeline d-flex flex-column gap-3 mt-3">
      <% approval_request.approval_steps.each do |step| %>
        <% step_theme = case step.effective_status
           when "approved" then { border: "#2d6a4f", bg: "#f0fff4", text: "#2d6a4f", icon: "✓" }
           when "rejected" then { border: "#a52a2a", bg: "#fff5f5", text: "#a52a2a", icon: "✕" }
           when "pending" then { border: "#1a75ff", bg: "#f0f7ff", text: "#1a75ff", icon: "●" }
           else { border: "#6c757d", bg: "#f8f9fa", text: "#6c757d", icon: "○" }
           end %>
        <div class="p-3 border-start border-4 rounded shadow-sm" style="border-color: <%= step_theme[:border] %> !important; background-color: <%= step_theme[:bg] %>;">
          <div class="d-flex justify-content-between align-items-start border-bottom pb-2 mb-2">
            <div>
              <span class="badge" style="background-color: <%= step_theme[:border] %>; color: white;">Level <%= step.level %></span>
              <strong class="ms-2" style="color: #1a3a2a; font-size: 1.1rem;"><%= step.employee_master.name %></strong>
              <span class="text-muted small ms-1">(<%= step.employee_master.designation.presence || "Employee" %>)</span>
            </div>
            <div class="fw-bold px-3 py-1 rounded-pill border" style="background: white; border-color: <%= step_theme[:border] %> !important; color: <%= step_theme[:text] %>; font-size: 0.85rem;">
              <span class="me-1"><%= step_theme[:icon] %></span> <%= step.effective_status_label %>
            </div>
          </div>

          <div class="row g-3 small">
            <div class="col-md-4">
              <div class="text-muted mb-1">From Action</div>
              <div class="fw-semibold"><%= step.previous_action_label %></div>
            </div>
            <div class="col-md-4">
              <div class="text-muted mb-1">To Action (Current)</div>
              <div class="fw-semibold" style="color: #0d9488;"><%= step.current_action_label %></div>
            </div>
            <div class="col-md-4">
              <div class="text-muted mb-1">Decision Time</div>
              <div class="fw-semibold text-muted">
                <%= step.actioned_at.present? ? step.actioned_at.strftime("%d-%m-%Y %H:%M") : "Pending..." %>
              </div>
            </div>
          </div>

          <% if step.remark.present? %>
            <div class="mt-2 pt-2 border-top">
              <div class="text-muted small mb-1">Remark</div>
              <div class="p-2 rounded bg-white bg-opacity-50">
                "<%= step.remark %>"
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<div class="app-page-header" style="margin-top: 1.5rem; display: flex; justify-content: space-between; align-items: center; gap: 1rem;">
  <div>
    <h3 style="margin-bottom: 0.25rem;">Proposal Items</h3>
    <p class="app-section-note mb-0">Requested items and quantities for this quotation proposal.</p>
  </div>
  <span class="badge border bg-light text-dark px-3 py-2" style="font-size: 0.9rem;">
    Total Items: <%= @quotation_proposal.quotation_proposal_items.size %>
  </span>
</div>

<div class="app-table-wrap">
  <table class="table app-table">
    <thead>
      <tr>
        <th>Item Name</th>
        <th>Unit</th>
        <th>Quantity</th>
        <th>Remark</th>
      </tr>
    </thead>
    <tbody>
      <% @quotation_proposal.quotation_proposal_items.each do |item| %>
        <tr>
          <td><%= item.item_name %></td>
          <td><%= item.unit.name %></td>
          <td><%= item.quantity %></td>
          <td><%= item.remark.presence || "-" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
