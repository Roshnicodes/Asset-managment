<div class="app-page-header">
  <h2>Quotation Proposal Details</h2>
  <%= link_to "Back", quotation_proposals_path, class: "app-back-link" %>
</div>

<div class="app-detail-actions">
  <%= link_to "Edit", edit_quotation_proposal_path(@quotation_proposal), class: "app-secondary-btn" %>
  <% if @quotation_proposal.approval_request.blank? %>
    <%= button_to "Send for Approval", send_for_approval_quotation_proposal_path(@quotation_proposal), method: :post, class: "app-form-submit" %>
  <% end %>
</div>

<div class="app-detail-card">
  <div class="app-detail-grid">
    <div class="app-detail-item">
      <div class="app-detail-label">Subject</div>
      <div class="app-detail-value"><%= @quotation_proposal.subject %></div>
    </div>

    <div class="app-detail-item">
      <div class="app-detail-label">Theme</div>
      <div class="app-detail-value"><%= @quotation_proposal.theme.name %></div>
    </div>

    <div class="app-detail-item">
      <div class="app-detail-label">Proposal End Date</div>
      <div class="app-detail-value"><%= @quotation_proposal.proposal_end_date.strftime("%d-%m-%Y") %></div>
    </div>

    <div class="app-detail-item">
      <div class="app-detail-label">Approval Status</div>
      <div class="app-detail-value"><%= @quotation_proposal.approval_request&.status_label || "Draft" %></div>
    </div>

    <div class="app-detail-item" style="grid-column: 1 / -1;">
      <div class="app-detail-label">Selected Vendors</div>
      <div class="app-detail-value"><%= @quotation_proposal.vendor_registrations.map(&:display_name).join(", ") %></div>
    </div>

    <div class="app-detail-item" style="grid-column: 1 / -1;">
      <div class="app-detail-label">Remark</div>
      <div class="app-detail-value"><%= @quotation_proposal.remark.presence || "-" %></div>
    </div>

    <div class="app-detail-item" style="grid-column: 1 / -1;">
      <div class="app-detail-label">Approval Trail</div>
      <div class="app-detail-value"><%= @quotation_proposal.approval_request&.approval_history_label || "-" %></div>
    </div>
  </div>
</div>

<div class="app-page-header" style="margin-top: 1rem;">
  <h3>Proposal Items</h3>
</div>

<div class="app-table-wrap">
  <table class="table app-table">
    <thead>
      <tr>
        <th>Item Name</th>
        <th>Unit</th>
        <th>Quantity</th>
        <th>Remark</th>
      </tr>
    </thead>
    <tbody>
      <% @quotation_proposal.quotation_proposal_items.each do |item| %>
        <tr>
          <td><%= item.item_name %></td>
          <td><%= item.unit.name %></td>
          <td><%= item.quantity %></td>
          <td><%= item.remark.presence || "-" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
