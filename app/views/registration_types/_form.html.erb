<%= form_with(model: registration_type) do |form| %>
  <div class="app-form-card">
    <% if registration_type.errors.any? %>
      <div class="app-form-errors">
        <h2><%= pluralize(registration_type.errors.count, "error") %> found</h2>
        <ul>
          <% registration_type.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="app-form-grid">
      <div class="app-form-field">
        <%= form.label :name, "Registration Type Name" %>
        <%= form.text_field :name %>
      </div>

      <div class="app-form-field">
        <%= form.label :stakeholder_category_id, "Stakeholder" %>
        <%= form.collection_select :stakeholder_category_id, StakeholderCategory.order(:name), :id, :name, { prompt: "Select stakeholder" } %>
      </div>
    </div>

    <div class="app-form-actions">
      <%= form.submit "Save Registration Type", class: "app-form-submit" %>
    </div>
  </div>
<% end %>
