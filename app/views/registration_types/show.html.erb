<div class="app-page-header">
  <h2>Registration Type Details</h2>
  <%= link_to "Back", registration_types_path, class: "app-back-link" %>
</div>

<%= render @registration_type %>

<div class="app-detail-actions">
  <%= link_to "Edit", edit_registration_type_path(@registration_type), class: "app-secondary-btn" %>
  <%= button_to "Delete", @registration_type, method: :delete, data: { turbo_confirm: "Delete this registration type?" }, class: "app-danger-btn" %>
</div>
