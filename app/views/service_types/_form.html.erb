<%= form_with(model: service_type) do |form| %>
  <div class="app-form-card">
    <% if service_type.errors.any? %>
      <div class="app-form-errors">
        <h2><%= pluralize(service_type.errors.count, "error") %> found</h2>
        <ul>
          <% service_type.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="app-form-grid">
      <div class="app-form-field">
        <%= form.label :name, "Service Type Name" %>
        <%= form.text_field :name %>
      </div>
    </div>

    <div class="app-form-actions">
      <%= form.submit "Save Service Type", class: "app-form-submit" %>
    </div>
  </div>
<% end %>
