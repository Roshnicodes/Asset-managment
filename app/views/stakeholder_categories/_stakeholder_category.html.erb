<div id="<%= dom_id stakeholder_category %>" class="app-detail-card">
  <div class="app-detail-grid">
    <div class="app-detail-item">
      <div class="app-detail-label">Stakeholder Name</div>
      <div class="app-detail-value"><%= stakeholder_category.name %></div>
    </div>

    <div class="app-detail-item">
      <div class="app-detail-label">Office Category</div>
      <div class="app-detail-value"><%= stakeholder_category.office_category&.name || "Not linked" %></div>
    </div>

    <div class="app-detail-item">
      <div class="app-detail-label">Firm Type</div>
      <div class="app-detail-value"><%= stakeholder_category.firm_type.presence || "-" %></div>
    </div>
  </div>
</div>
