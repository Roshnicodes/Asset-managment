<div class="app-toolbar">
  <div>
    <h1>Stakeholder Categories</h1>
    <p class="app-section-note">Examples: ASA, PGPL, PAPL.</p>
  </div>
  <%= link_to "Add Stakeholder Category", new_stakeholder_category_path, class: "app-primary-btn" %>
</div>

<div class="app-table-wrap">
  <table class="table app-table">
    <thead>
      <tr>
        <th>Stakeholder Name</th>
        <th>Contact No</th>
        <th>Email ID</th>
        <th>Firm Type</th>
        <th>Logo</th>
        <th>Address</th>
        <th>Action</th>
      </tr>
    </thead>
    <tbody>
      <% @stakeholder_categories.each do |stakeholder_category| %>
        <tr>
          <td><%= stakeholder_category.name %></td>
          <td><%= stakeholder_category.contact_no %></td>
          <td><%= stakeholder_category.email_id %></td>
          <td><%= stakeholder_category.firm_type.presence || "-" %></td>
          <td>
            <% if stakeholder_category.logo_file.attached? %>
              <%= image_tag stakeholder_category.logo_file, class: "app-stakeholder-logo-thumb", alt: "Stakeholder logo" %>
            <% elsif stakeholder_category.logo_url.present? %>
              <%= image_tag stakeholder_category.logo_url, class: "app-stakeholder-logo-thumb", alt: "Stakeholder logo" %>
            <% else %>
              -
            <% end %>
          </td>
          <td><%= stakeholder_category.address %></td>
          <td class="app-row-actions">
            <%= link_to "Edit", edit_stakeholder_category_path(stakeholder_category) %> |
            <%= button_to "Delete", stakeholder_category_path(stakeholder_category), method: :delete, data: { turbo_confirm: "Delete this stakeholder category?" }, class: "app-action-button app-delete-button" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
