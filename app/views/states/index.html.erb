<div class="app-toolbar">
  <div>
    <h1>LG - States</h1>
    <p class="app-section-note">LG includes State, District, and Block.</p>
  </div>
  <%= link_to "Add State", new_state_path, class: "app-primary-btn" %>
</div>

<div class="app-table-wrap">
  <table class="table app-table">
    <thead>
      <tr>
        <th>State Name</th>
        <th>Action</th>
      </tr>
    </thead>
    <tbody>
      <% @states.each do |state| %>
        <tr>
          <td><%= state.name %></td>
          <td class="app-row-actions">
            <%= link_to "Edit", edit_state_path(state) %> |
            <%= button_to "Delete", state_path(state), method: :delete, data: { turbo_confirm: "Delete this state?" }, class: "app-action-button app-delete-button" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
