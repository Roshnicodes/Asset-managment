<h1>Vendor Thematic Types</h1>

<%= link_to "Add Thematic Type", new_theme_path, class: "btn btn-primary mb-3" %>

<table class="table table-bordered">

<tr>
<th>Thematic Type Name</th>
<th>Action</th>
</tr>

<% @themes.each do |theme| %>

<tr>

<td><%= theme.name %></td>

<td>
<%= link_to "Edit", edit_theme_path(theme) %> |
<%= link_to "Delete", theme, method: :delete, data: { turbo_confirm: "Delete this thematic type?" } %>
</td>

</tr>

<% end %>

</table>
