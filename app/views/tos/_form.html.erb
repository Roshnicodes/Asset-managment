<%= form_with model: @to do |f| %>
  <div class="app-form-card">
    <div class="app-form-grid two-col">
      <div class="app-form-field">
        <%= f.label :fco_id, "FCO" %>
        <%= f.select :fco_id, options_for_select(@fcos.map { |fco| ["#{fco.state.name} / #{fco.district.name} / #{fco.block&.name || '-'} / #{fco.pmu.name} / #{fco.name}", fco.id] }, @to.fco_id), { prompt: "Select FCO" } %>
      </div>

      <div class="app-form-field">
        <%= f.label :name, "TO Name" %>
        <%= f.text_field :name %>
      </div>
    </div>

    <div class="app-form-actions">
      <%= f.submit "Save TO", class: "app-form-submit" %>
    </div>
  </div>
<% end %>
