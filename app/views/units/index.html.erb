<div class="app-toolbar">
  <h1>Units</h1>
  <%= link_to "Add Unit", new_unit_path, class: "app-primary-btn" %>
</div>

<div class="app-table-wrap">
  <table class="table app-table">
    <thead>
      <tr>
        <th>Unit Name</th>
        <th>Action</th>
      </tr>
    </thead>
    <tbody>
      <% @units.each do |unit| %>
        <tr>
          <td><%= unit.name %></td>
          <td class="app-row-actions">
            <%= link_to "Edit", edit_unit_path(unit) %> |
            <%= button_to "Delete", unit_path(unit), method: :delete, data: { turbo_confirm: "Delete this unit?" }, class: "app-action-button app-delete-button" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
