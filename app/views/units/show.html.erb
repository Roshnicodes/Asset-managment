<div class="app-page-header">
  <h2>Unit Details</h2>
  <%= link_to "Back", units_path, class: "app-back-link" %>
</div>

<%= render @unit %>

<div class="app-detail-actions">
  <%= link_to "Edit", edit_unit_path(@unit), class: "app-secondary-btn" %>
  <%= button_to "Delete", @unit, method: :delete, data: { turbo_confirm: "Delete this unit?" }, class: "app-danger-btn" %>
</div>
