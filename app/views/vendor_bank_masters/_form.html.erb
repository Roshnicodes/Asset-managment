<%= form_with(model: vendor_bank_master) do |form| %>
  <div class="app-form-card">
    <% if vendor_bank_master.errors.any? %>
      <div class="app-form-errors">
        <h2><%= pluralize(vendor_bank_master.errors.count, "error") %> found</h2>
        <ul>
          <% vendor_bank_master.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="app-form-grid two-col">
      <div class="app-form-field">
        <%= form.label :vendor_registration_id, "Select Vendor / Employee Name" %>
        <%= form.collection_select :vendor_registration_id, @vendor_registrations, :id, :display_name, { prompt: "Select vendor" }, class: "form-control" %>
      </div>

      <div class="app-form-field">
        <%= form.label :bank_name, "Bank Name" %>
        <%= form.text_field :bank_name, class: "form-control" %>
      </div>

      <div class="app-form-field">
        <%= form.label :ifsc_code, "Bank IFSC Code" %>
        <%= form.text_field :ifsc_code, class: "form-control" %>
      </div>

      <div class="app-form-field">
        <%= form.label :account_number, "Account No" %>
        <%= form.text_field :account_number, class: "form-control" %>
      </div>

      <div class="app-form-field">
        <%= form.label :account_type, "Bank Type Category" %>
        <%= form.select :account_type, VendorBankMaster::ACCOUNT_TYPES, { prompt: "Select account type" }, class: "form-control" %>
      </div>

      <div class="app-form-field">
        <%= form.label :bank_address, "Bank Address" %>
        <%= form.text_area :bank_address, class: "form-control", rows: 3 %>
      </div>
    </div>

    <div class="app-form-actions">
      <%= form.submit "Save Bank Detail", class: "app-form-submit" %>
    </div>
  </div>
<% end %>
