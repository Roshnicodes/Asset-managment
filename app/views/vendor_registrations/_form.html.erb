<%= form_with(model: vendor_registration) do |form| %>
  <div class="app-form-card app-form-card-wide">
    <% if vendor_registration.errors.any? %>
      <div class="app-form-errors">
        <h2>Please fix the following details:</h2>
        <ul>
          <% vendor_registration.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="app-form-section">
      <div class="app-form-section-title">Basic Information</div>
      <p class="app-form-section-note">Registration type, firm details, and vendor identity.</p>
    </div>

    <div class="app-form-grid two-col">
      <div class="app-form-field">
        <%= form.label :stakeholder_category_id, "Stakeholder Name" %>
        <%= form.collection_select :stakeholder_category_id, @stakeholder_categories, :id, :name, { prompt: "Select stakeholder" } %>
      </div>

      <div class="app-form-field">
        <%= form.label :registration_type_id, "Registration Type" %>
        <%= form.collection_select :registration_type_id, @registration_types, :id, :name, { prompt: "Select registration type" } %>
      </div>

      <div class="app-form-field">
        <%= form.label :firm_id, "Firm Name" %>
        <%= form.collection_select :firm_id, @firms, :id, :name, { prompt: "Select firm" } %>
      </div>
    </div>

    <div class="app-form-grid three-col">
      <div class="app-form-field">
        <%= form.label :company_name, "Company Name" %>
        <%= form.text_field :company_name %>
      </div>

      <div class="app-form-field">
        <%= form.label :vendor_name, "Vendor Name" %>
        <%= form.text_field :vendor_name %>
      </div>

      <div class="app-form-field">
        <%= form.label :firm_type, "Firm Type" %>
        <%= form.text_field :firm_type %>
      </div>
    </div>

    <div class="app-form-section">
      <div class="app-form-section-title">Contact and Location</div>
      <p class="app-form-section-note">Business contact details and LG mapping.</p>
    </div>

    <div class="app-form-grid four-col">
      <div class="app-form-field">
        <%= form.label :gst_no, "GST No" %>
        <%= form.text_field :gst_no %>
      </div>

      <div class="app-form-field">
        <%= form.label :pan_no, "PAN No" %>
        <%= form.text_field :pan_no %>
      </div>

      <div class="app-form-field">
        <%= form.label :email, "Email" %>
        <%= form.email_field :email %>
      </div>

      <div class="app-form-field">
        <%= form.label :mobile_no, "Mobile No" %>
        <%= form.telephone_field :mobile_no %>
      </div>
    </div>

    <div class="app-form-grid four-col">
      <div class="app-form-field">
        <%= form.label :state_id, "State" %>
        <%= form.collection_select :state_id, @states, :id, :name, { prompt: "Select state" } %>
      </div>

      <div class="app-form-field">
        <%= form.label :district_id, "District" %>
        <%= form.collection_select :district_id, @districts, :id, :name, { prompt: "Select district" } %>
      </div>

      <div class="app-form-field">
        <%= form.label :block_id, "Block" %>
        <%= form.collection_select :block_id, @blocks, :id, :name, { prompt: "Select block" } %>
      </div>

      <div class="app-form-field">
        <%= form.label :pin_no, "PIN No" %>
        <%= form.text_field :pin_no %>
      </div>
    </div>

    <div class="app-form-grid two-col">
      <div class="app-form-field">
        <%= form.label :contact_person_name, "Name of Contact Person" %>
        <%= form.text_field :contact_person_name %>
      </div>

      <div class="app-form-field">
        <%= form.label :contact_person_designation, "Designation of Contact Person" %>
        <%= form.text_field :contact_person_designation %>
      </div>
    </div>

    <div class="app-form-section">
      <div class="app-form-section-title">Business Status</div>
      <p class="app-form-section-note">MSME and company activity details.</p>
    </div>

    <div class="app-form-grid three-col">
      <div class="app-form-field">
        <%= form.label :msme, "Is your firm MSME?" %>
        <%= form.select :msme, [["Yes", true], ["No", false]], { prompt: "Select MSME status" } %>
      </div>

      <div class="app-form-field">
        <%= form.label :msme_number, "MSME No" %>
        <%= form.text_field :msme_number %>
      </div>

      <div class="app-form-field">
        <%= form.label :company_status, "Status of Company" %>
        <%= form.select :company_status, ["Active", "Inactive"], { prompt: "Select company status" } %>
      </div>
    </div>

    <div class="app-form-section">
      <div class="app-form-section-title">Theme and Product Selection</div>
      <p class="app-form-section-note">Pehle theme select karein, phir uske according product aur product variety choose karein.</p>
    </div>

    <div class="app-form-grid">
      <div class="app-form-field">
        <%= form.label :theme_ids, "Theme Name" %>
        <p class="app-checkbox-note">Multiple selection ke liye checkbox use karein.</p>
        <%= hidden_field_tag "vendor_registration[theme_ids][]", "" %>
        <div class="app-checkbox-grid">
          <% @themes.each do |theme| %>
            <label class="app-checkbox-card">
              <%= check_box_tag "vendor_registration[theme_ids][]", theme.id, vendor_registration.theme_ids.include?(theme.id), class: "vendor-theme-checkbox", data: { theme_id: theme.id } %>
              <span><%= theme.name %></span>
            </label>
          <% end %>
        </div>
      </div>

      <div class="app-form-field">
        <%= form.label :product_ids, "Product Name" %>
        <p class="app-checkbox-note">Selected theme ke according products dikhenge.</p>
        <%= hidden_field_tag "vendor_registration[product_ids][]", "" %>
        <div class="app-checkbox-grid">
          <% @products.each do |product| %>
            <label class="app-checkbox-card vendor-product-card" data-theme-id="<%= product.theme_id %>">
              <%= check_box_tag "vendor_registration[product_ids][]", product.id, vendor_registration.product_ids.include?(product.id), class: "vendor-product-checkbox", data: { theme_id: product.theme_id, product_id: product.id } %>
              <span><%= "#{product.theme.name} - #{product.name}" %></span>
            </label>
          <% end %>
        </div>
      </div>

      <div class="app-form-field">
        <%= form.label :product_variety_ids, "Product Variety Name" %>
        <p class="app-checkbox-note">Selected product ke according product varieties dikhenge.</p>
        <%= hidden_field_tag "vendor_registration[product_variety_ids][]", "" %>
        <div class="app-checkbox-grid">
          <% @product_varieties.each do |product_variety| %>
            <label class="app-checkbox-card vendor-variety-card" data-product-id="<%= product_variety.product_id %>">
              <%= check_box_tag "vendor_registration[product_variety_ids][]", product_variety.id, vendor_registration.product_variety_ids.include?(product_variety.id), class: "vendor-variety-checkbox", data: { product_id: product_variety.product_id } %>
              <span><%= "#{product_variety.product.name} - #{product_variety.name}" %></span>
            </label>
          <% end %>
        </div>
      </div>

      <div class="app-form-field">
        <%= form.label :business_description, "Brief Description of Business" %>
        <%= form.text_area :business_description, rows: 4 %>
      </div>
    </div>

    <p class="app-section-note">Submit time and user IP are saved automatically on submit.</p>

    <div class="app-form-actions">
      <%= form.submit "Submit Registration", class: "app-form-submit" %>
    </div>
  </div>
<% end %>
