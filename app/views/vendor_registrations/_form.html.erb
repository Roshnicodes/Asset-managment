<%= form_with(model: vendor_registration) do |form| %>
  <% if vendor_registration.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% vendor_registration.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="row">
    <div class="col-md-6 mb-3">
      <%= form.label :registration_type_id, "Registration Type", class: "form-label" %>
      <%= form.collection_select :registration_type_id, @registration_types, :id, :name, { prompt: "Select registration type" }, class: "form-control" %>
    </div>
    <div class="col-md-6 mb-3">
      <%= form.label :firm_id, "Firm Name", class: "form-label" %>
      <%= form.collection_select :firm_id, @firms, :id, :name, { prompt: "Select firm" }, class: "form-control" %>
    </div>
  </div>

  <div class="row">
    <div class="col-md-4 mb-3">
      <%= form.label :company_name, class: "form-label" %>
      <%= form.text_field :company_name, class: "form-control" %>
    </div>
    <div class="col-md-4 mb-3">
      <%= form.label :vendor_name, class: "form-label" %>
      <%= form.text_field :vendor_name, class: "form-control" %>
    </div>
    <div class="col-md-4 mb-3">
      <%= form.label :firm_type, class: "form-label" %>
      <%= form.text_field :firm_type, class: "form-control" %>
    </div>
  </div>

  <div class="row">
    <div class="col-md-3 mb-3">
      <%= form.label :gst_no, "GST No", class: "form-label" %>
      <%= form.text_field :gst_no, class: "form-control" %>
    </div>
    <div class="col-md-3 mb-3">
      <%= form.label :pan_no, "PAN No", class: "form-label" %>
      <%= form.text_field :pan_no, class: "form-control" %>
    </div>
    <div class="col-md-3 mb-3">
      <%= form.label :email, class: "form-label" %>
      <%= form.email_field :email, class: "form-control" %>
    </div>
    <div class="col-md-3 mb-3">
      <%= form.label :mobile_no, class: "form-label" %>
      <%= form.telephone_field :mobile_no, class: "form-control" %>
    </div>
  </div>

  <div class="row">
    <div class="col-md-3 mb-3">
      <%= form.label :state_id, class: "form-label" %>
      <%= form.collection_select :state_id, @states, :id, :name, { prompt: "Select state" }, class: "form-control" %>
    </div>
    <div class="col-md-3 mb-3">
      <%= form.label :district_id, class: "form-label" %>
      <%= form.collection_select :district_id, @districts, :id, :name, { prompt: "Select district" }, class: "form-control" %>
    </div>
    <div class="col-md-3 mb-3">
      <%= form.label :block_id, class: "form-label" %>
      <%= form.collection_select :block_id, @blocks, :id, :name, { prompt: "Select block" }, class: "form-control" %>
    </div>
    <div class="col-md-3 mb-3">
      <%= form.label :pin_no, "PIN No", class: "form-label" %>
      <%= form.text_field :pin_no, class: "form-control" %>
    </div>
  </div>

  <div class="row">
    <div class="col-md-6 mb-3">
      <%= form.label :contact_person_name, "Name of Contact Person", class: "form-label" %>
      <%= form.text_field :contact_person_name, class: "form-control" %>
    </div>
    <div class="col-md-6 mb-3">
      <%= form.label :contact_person_designation, "Designation of Contact Person", class: "form-label" %>
      <%= form.text_field :contact_person_designation, class: "form-control" %>
    </div>
  </div>

  <div class="row">
    <div class="col-md-4 mb-3">
      <div class="form-check mt-4">
        <%= form.check_box :msme, class: "form-check-input" %>
        <%= form.label :msme, "Is your firm MSME?", class: "form-check-label" %>
      </div>
    </div>
    <div class="col-md-4 mb-3">
      <%= form.label :msme_number, "MSME No", class: "form-label" %>
      <%= form.text_field :msme_number, class: "form-control" %>
    </div>
    <div class="col-md-4 mb-3">
      <%= form.label :company_status, "Status of Company", class: "form-label" %>
      <%= form.select :company_status, ["Active", "Inactive"], { prompt: "Select company status" }, class: "form-control" %>
    </div>
  </div>

  <div class="mb-3">
    <%= form.label :theme_ids, "Theme Name (Multiple Selection)", class: "form-label" %>
    <%= form.collection_select :theme_ids, @themes, :id, :name, {}, class: "form-control", multiple: true, size: 5 %>
  </div>

  <div class="mb-3">
    <%= form.label :product_ids, "Product Name (Multiple Selection)", class: "form-label" %>
    <%= form.collection_select :product_ids, @products, :id, :name, {}, class: "form-control", multiple: true, size: 5 %>
  </div>

  <div class="mb-3">
    <%= form.label :product_variety_ids, "Product Variety Name (Multiple Selection)", class: "form-label" %>
    <%= form.collection_select :product_variety_ids, @product_varieties, :id, :name, {}, class: "form-control", multiple: true, size: 5 %>
  </div>

  <div class="mb-3">
    <%= form.label :business_description, "Brief Description of Business", class: "form-label" %>
    <%= form.text_area :business_description, class: "form-control", rows: 4 %>
  </div>

  <div class="alert alert-info">
    Submit time and user IP are saved automatically on submit.
  </div>

  <%= form.submit "Submit Registration", class: "btn btn-primary" %>
<% end %>
