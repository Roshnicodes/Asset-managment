<%= form_with(model: vendor_registration) do |form| %>
  <div class="app-form-card app-form-card-wide">
    <div class="app-form-grid two-col">
      <div class="app-form-field">
        <%= form.label :registration_type_id, "Registration Type" %>
        <%= form.collection_select :registration_type_id, @registration_types, :id, :name, { prompt: "Select registration type" } %>
      </div>

      <div class="app-form-field">
        <%= form.label :firm_id, "Firm Name" %>
        <%= form.collection_select :firm_id, @firms, :id, :name, { prompt: "Select firm" } %>
      </div>
    </div>

    <div class="app-form-grid three-col">
      <div class="app-form-field">
        <%= form.label :company_name, "Company Name" %>
        <%= form.text_field :company_name %>
      </div>

      <div class="app-form-field">
        <%= form.label :vendor_name, "Vendor Name" %>
        <%= form.text_field :vendor_name %>
      </div>

      <div class="app-form-field">
        <%= form.label :firm_type, "Firm Type" %>
        <%= form.text_field :firm_type %>
      </div>
    </div>

    <div class="app-form-grid four-col">
      <div class="app-form-field">
        <%= form.label :gst_no, "GST No" %>
        <%= form.text_field :gst_no %>
      </div>

      <div class="app-form-field">
        <%= form.label :pan_no, "PAN No" %>
        <%= form.text_field :pan_no %>
      </div>

      <div class="app-form-field">
        <%= form.label :email, "Email" %>
        <%= form.email_field :email %>
      </div>

      <div class="app-form-field">
        <%= form.label :mobile_no, "Mobile No" %>
        <%= form.telephone_field :mobile_no %>
      </div>
    </div>

    <div class="app-form-grid four-col">
      <div class="app-form-field">
        <%= form.label :state_id, "State" %>
        <%= form.collection_select :state_id, @states, :id, :name, { prompt: "Select state" } %>
      </div>

      <div class="app-form-field">
        <%= form.label :district_id, "District" %>
        <%= form.collection_select :district_id, @districts, :id, :name, { prompt: "Select district" } %>
      </div>

      <div class="app-form-field">
        <%= form.label :block_id, "Block" %>
        <%= form.collection_select :block_id, @blocks, :id, :name, { prompt: "Select block" } %>
      </div>

      <div class="app-form-field">
        <%= form.label :pin_no, "PIN No" %>
        <%= form.text_field :pin_no %>
      </div>
    </div>

    <div class="app-form-grid two-col">
      <div class="app-form-field">
        <%= form.label :contact_person_name, "Name of Contact Person" %>
        <%= form.text_field :contact_person_name %>
      </div>

      <div class="app-form-field">
        <%= form.label :contact_person_designation, "Designation of Contact Person" %>
        <%= form.text_field :contact_person_designation %>
      </div>
    </div>

    <div class="app-form-grid three-col">
      <div class="app-form-field">
        <%= form.label :msme, "Is your firm MSME?" %>
        <%= form.select :msme, [["Yes", true], ["No", false]], { prompt: "Select MSME status" } %>
      </div>

      <div class="app-form-field">
        <%= form.label :msme_number, "MSME No" %>
        <%= form.text_field :msme_number %>
      </div>

      <div class="app-form-field">
        <%= form.label :company_status, "Status of Company" %>
        <%= form.select :company_status, ["Active", "Inactive"], { prompt: "Select company status" } %>
      </div>
    </div>

    <div class="app-form-grid">
      <div class="app-form-field">
        <%= form.label :theme_ids, "Theme Name (Multiple Selection)" %>
        <%= form.collection_select :theme_ids, @themes, :id, :name, {}, multiple: true, size: 5 %>
      </div>

      <div class="app-form-field">
        <%= form.label :product_ids, "Product Name (Multiple Selection)" %>
        <%= form.collection_select :product_ids, @products, :id, :name, {}, multiple: true, size: 5 %>
      </div>

      <div class="app-form-field">
        <%= form.label :product_variety_ids, "Product Variety Name (Multiple Selection)" %>
        <%= form.collection_select :product_variety_ids, @product_varieties, :id, :name, {}, multiple: true, size: 5 %>
      </div>

      <div class="app-form-field">
        <%= form.label :business_description, "Brief Description of Business" %>
        <%= form.text_area :business_description, rows: 4 %>
      </div>
    </div>

    <p class="app-section-note">Submit time and user IP are saved automatically on submit.</p>

    <div class="app-form-actions">
      <%= form.submit "Submit Registration", class: "app-form-submit" %>
    </div>
  </div>
<% end %>
