<div class="app-form-grid two-col">
  <div class="app-form-field">
    <%= form.label :bank_name, "Bank Name" %>
    <%= form.select :bank_name, VendorBankMaster.masters.pluck(:bank_name), { prompt: "Select bank name" } %>
  </div>

  <div class="app-form-field">
    <%= form.label :account_type, "Bank Type Category" %>
    <%= form.select :account_type, VendorBankMaster::ACCOUNT_TYPES, { prompt: "Select account type" } %>
  </div>

  <div class="app-form-field">
    <%= form.label :account_number, "Account No" %>
    <%= form.text_field :account_number %>
  </div>

  <div class="app-form-field">
    <%= form.label :ifsc_code, "Bank IFSC Code" %>
    <%= form.text_field :ifsc_code %>
  </div>

  <div class="app-form-field">
    <%= form.label :bank_address, "Bank Address" %>
    <%= form.text_area :bank_address, rows: 3 %>
  </div>

  <div class="app-form-field">
    <%= form.label :cancelled_cheque, "Check Book / Cancelled Cheque" %>
    <%= form.file_field :cancelled_cheque, accept: ".pdf,image/*" %>
    <% if form.object.cancelled_cheque.attached? %>
      <p class="app-section-note" style="margin-top: 0.5rem;">
        Current file:
        <%= link_to form.object.cancelled_cheque.filename.to_s, rails_blob_path(form.object.cancelled_cheque, disposition: "attachment"), target: "_blank", rel: "noopener" %>
      </p>
    <% end %>
  </div>
</div>
