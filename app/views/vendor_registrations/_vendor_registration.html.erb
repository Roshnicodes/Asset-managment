<% approval_request = vendor_registration.approval_request %>

<div id="<%= dom_id vendor_registration %>" class="app-detail-card">
  <div class="app-detail-grid">
    <div class="app-detail-item">
      <div class="app-detail-label">Stakeholder</div>
      <div class="app-detail-value"><%= vendor_registration.stakeholder_category&.name || "-" %></div>
    </div>

    <div class="app-detail-item">
      <div class="app-detail-label">Registration Type</div>
      <div class="app-detail-value"><%= vendor_registration.registration_type&.name %></div>
    </div>

    <div class="app-detail-item">
      <div class="app-detail-label">Firm</div>
      <div class="app-detail-value"><%= vendor_registration.firm&.name %></div>
    </div>

    <div class="app-detail-item">
      <div class="app-detail-label">Firm Name</div>
      <div class="app-detail-value"><%= vendor_registration.firm_name %></div>
    </div>

    <div class="app-detail-item">
      <div class="app-detail-label">Vendor Name</div>
      <div class="app-detail-value"><%= vendor_registration.vendor_name %></div>
    </div>

    <div class="app-detail-item">
      <div class="app-detail-label">Firm Type</div>
      <div class="app-detail-value"><%= vendor_registration.firm_type %></div>
    </div>

    <div class="app-detail-item">
      <div class="app-detail-label">GST No</div>
      <div class="app-detail-value"><%= vendor_registration.gst_no %></div>
    </div>

    <div class="app-detail-item">
      <div class="app-detail-label">PAN No</div>
      <div class="app-detail-value"><%= vendor_registration.pan_no %></div>
    </div>

    <div class="app-detail-item">
      <div class="app-detail-label">Email</div>
      <div class="app-detail-value"><%= vendor_registration.email %></div>
    </div>

    <div class="app-detail-item">
      <div class="app-detail-label">Mobile No</div>
      <div class="app-detail-value"><%= vendor_registration.mobile_no %></div>
    </div>

    <div class="app-detail-item">
      <div class="app-detail-label">State</div>
      <div class="app-detail-value"><%= vendor_registration.state&.name %></div>
    </div>

    <div class="app-detail-item">
      <div class="app-detail-label">District</div>
      <div class="app-detail-value"><%= vendor_registration.district&.name %></div>
    </div>

    <div class="app-detail-item">
      <div class="app-detail-label">Block</div>
      <div class="app-detail-value"><%= vendor_registration.block&.name %></div>
    </div>

    <div class="app-detail-item">
      <div class="app-detail-label">PIN No</div>
      <div class="app-detail-value"><%= vendor_registration.pin_no %></div>
    </div>

    <div class="app-detail-item">
      <div class="app-detail-label">Contact Person</div>
      <div class="app-detail-value"><%= vendor_registration.contact_person_name %></div>
    </div>

    <div class="app-detail-item">
      <div class="app-detail-label">Contact Designation</div>
      <div class="app-detail-value"><%= vendor_registration.contact_person_designation %></div>
    </div>

    <div class="app-detail-item">
      <div class="app-detail-label">MSME</div>
      <div class="app-detail-value"><%= vendor_registration.msme ? "Yes" : "No" %></div>
    </div>

    <div class="app-detail-item">
      <div class="app-detail-label">MSME Number</div>
      <div class="app-detail-value"><%= vendor_registration.msme_number.presence || "-" %></div>
    </div>

    <div class="app-detail-item">
      <div class="app-detail-label">Company Status</div>
      <div class="app-detail-value"><%= vendor_registration.company_status %></div>
    </div>

    <div class="app-detail-item">
      <div class="app-detail-label">Firm Profile</div>
      <div class="app-detail-value"><%= vendor_registration.firm_profile %></div>
    </div>

    <div class="app-detail-item">
      <div class="app-detail-label">Business Description</div>
      <div class="app-detail-value"><%= vendor_registration.business_description %></div>
    </div>

    <div class="app-detail-item">
      <div class="app-detail-label">Submitted At</div>
      <div class="app-detail-value"><%= vendor_registration.submitted_at %></div>
    </div>

    <div class="app-detail-item">
      <div class="app-detail-label">Submitted IP</div>
      <div class="app-detail-value"><%= vendor_registration.submitted_ip %></div>
    </div>

    <div class="app-detail-item">
      <div class="app-detail-label">Selected Themes</div>
      <div class="app-detail-value"><%= vendor_registration.themes.map(&:name).presence&.join(", ") || "-" %></div>
    </div>

    <div class="app-detail-item">
      <div class="app-detail-label">Selected Products</div>
      <div class="app-detail-value"><%= vendor_registration.products.map(&:name).presence&.join(", ") || "-" %></div>
    </div>

    <div class="app-detail-item">
      <div class="app-detail-label">Selected Product Varieties</div>
      <div class="app-detail-value"><%= vendor_registration.product_varieties.map(&:name).presence&.join(", ") || "-" %></div>
    </div>

    <div class="app-detail-item">
      <div class="app-detail-label">Approval Status</div>
      <div class="app-detail-value">
        <% badge_data = approval_status_badge_data(approval_request) %>
        <span class="badge border <%= badge_data[:css_class] %> fw-semibold px-3 py-2" style="font-size: 0.9rem;">
          <%= badge_data[:label] %>
        </span>
      </div>
    </div>

    <div class="app-detail-item">
      <div class="app-detail-label">Current Approver</div>
      <div class="app-detail-value">
        <% if vendor_registration.approval_request&.current_step %>
          <span class="badge border bg-info bg-opacity-10 text-info px-3 py-2" style="font-size: 0.9rem;">
            <%= vendor_registration.approval_request.current_step.employee_master.name %>
            <small>(<%= vendor_registration.approval_request.current_step.current_action_label %>)</small>
          </span>
        <% else %>
          -
        <% end %>
      </div>
    </div>

    <div class="app-detail-item" style="grid-column: 1 / -1;">
      <div class="app-detail-label">Approval Trail</div>
      <div class="app-detail-value">
        <% if approval_request %>
          <div class="d-flex flex-wrap gap-2 mt-2">
            <% approval_request.trail_steps.each do |step| %>
              <% step_class = case step.effective_status
                 when 'approved' then 'border-success bg-success bg-opacity-10 text-success'
                 when 'returned' then 'border-warning bg-warning bg-opacity-10 text-warning'
                 when 'rejected' then 'border-danger bg-danger bg-opacity-10 text-danger'
                 when 'pending' then 'border-info bg-info bg-opacity-10 text-info'
                 else 'border-secondary bg-light text-muted opacity-50'
                 end %>
              <div class="badge border <%= step_class %> px-3 py-2 text-start d-flex flex-column gap-1" style="font-style: normal; font-weight: normal; font-size: 0.85rem; line-height: 1.2;">
                <span class="fw-bold border-bottom pb-1 mb-1">Step <%= step.level %>: <%= step.employee_master.name %></span>
                <span>
                  <%= step.current_action_label %>
                  <% if step.show_status_in_trail? %>
                    : <strong><%= step.effective_status_label %></strong>
                  <% end %>
                </span>
                <% if step.actioned_at.present? %>
                  <span class="small opacity-75"><%= step.actioned_at.strftime("%d-%m-%Y %H:%M") %></span>
                <% end %>
              </div>
            <% end %>
          </div>
        <% else %>
          -
        <% end %>
      </div>
    </div>
  </div>
</div>
