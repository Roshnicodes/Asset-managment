<div class="app-toolbar">
  <h1>Vendor Registration Form</h1>
  <%= link_to "Add Vendor Registration", new_vendor_registration_path, class: "app-primary-btn" %>
</div>

<div class="app-table-wrap">
<table class="table app-table">
  <thead>
    <tr>
      <th>View</th>
      <th>Stakeholder</th>
      <th>Registration Type</th>
      <th>Vendor Name</th>
      <th>Company / Firm</th>
      <th>State</th>
      <th>Status</th>
      <th>Approval Status</th>
      <th>Approval Trail</th>
      <th>Submitted At</th>
      <th>Action</th>
    </tr>
  </thead>
  <tbody>
    <% @vendor_registrations.each do |vendor_registration| %>
      <tr>
        <td>
          <%= link_to vendor_registration_path(vendor_registration), class: "app-action-icon text-primary", title: "View" do %>
            <%= app_icon(:eye, size: 18) %>
          <% end %>
        </td>
        <td><%= vendor_registration.stakeholder_category&.name || "-" %></td>
        <td><%= vendor_registration.registration_type.name %></td>
        <td><%= vendor_registration.vendor_name %></td>
        <td><%= vendor_registration.company_name.presence || vendor_registration.firm&.name || "-" %></td>
        <td><%= vendor_registration.state.name %></td>
        <td><%= vendor_registration.company_status %></td>
        <td><%= vendor_registration.approval_request&.status&.capitalize || "Not Started" %></td>
        <td><%= vendor_registration.approval_request&.approval_history_label || "-" %></td>
        <td><%= vendor_registration.submitted_at&.strftime("%d-%m-%Y %H:%M") %></td>
        <td class="app-row-actions">
          <div class="d-flex align-items-center gap-2">
            <%= link_to edit_vendor_registration_path(vendor_registration), class: "app-action-icon text-warning", title: "Edit" do %>
              <%= app_icon(:pencil, size: 18) %>
            <% end %>
            <%= button_to vendor_registration_path(vendor_registration), method: :delete, data: { turbo_confirm: "Delete this vendor registration?" }, class: "app-action-icon text-danger", title: "Delete" do %>
              <%= app_icon(:trash, size: 18) %>
            <% end %>
          </div>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
</div>
