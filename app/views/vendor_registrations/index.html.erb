<div class="app-toolbar">
  <div class="d-flex align-items-center gap-3" style="width:100%">
    <h1 class="mb-0" style="white-space: nowrap;">Vendor Registration Form</h1>
    <div style="margin-left:auto; display:flex; gap:.5rem; align-items:center;">
      <%= link_to "Add Vendor Registration", new_vendor_registration_path, class: "app-primary-btn" %>
      <button type="submit" form="send-approval-form" class="app-secondary-btn d-none" id="send_for_approval_button">Send for Approval</button>
    </div>
  </div>
</div>

<%= form_tag send_for_approval_vendor_registrations_path, method: :post, id: "send-approval-form" do %>
<div class="app-table-wrap">
<table class="table app-table">
  <thead>
    <tr>
      <th>
        <input type="checkbox" id="select_all_checkbox" style="cursor: pointer;">
      </th>
      <th>View</th>
      <th>Stakeholder</th>
      <th>Registration Type</th>
      <th>Vendor Name</th>
      <th>Company / Firm</th>
      <th>State</th>
      <th>Status</th>
      <th>Approval Status</th>
      <th>Approval Trail</th>
      <th>Submitted At</th>
      <th>Action</th>
    </tr>
  </thead>
  <tbody>
    <% @vendor_registrations.each do |vendor_registration| %>
      <tr>
        <td>
          <input type="checkbox" name="vendor_registration_ids[]" value="<%= vendor_registration.id %>" class="row-approval-checkbox" style="cursor: pointer;">
        </td>
        <td>
          <%= link_to vendor_registration_path(vendor_registration), class: "app-action-icon text-primary", title: "View" do %>
            <%= app_icon(:eye, size: 18) %>
          <% end %>
        </td>
        <td><%= vendor_registration.stakeholder_category&.name || "-" %></td>
        <td><%= vendor_registration.registration_type.name %></td>
        <td><%= vendor_registration.vendor_name %></td>
        <td><%= vendor_registration.company_name.presence || vendor_registration.firm&.name || "-" %></td>
        <td><%= vendor_registration.state.name %></td>
        <td><%= vendor_registration.company_status %></td>
        <td><%= vendor_registration.approval_request&.status&.capitalize || "Not Started" %></td>
        <td><%= vendor_registration.approval_request&.approval_history_label || "-" %></td>
        <td><%= vendor_registration.submitted_at&.strftime("%d-%m-%Y %H:%M") %></td>
        <td class="app-row-actions">
          <div class="d-flex align-items-center gap-2">
            <%= link_to edit_vendor_registration_path(vendor_registration), class: "app-action-icon text-warning", title: "Edit" do %>
              <%= app_icon(:pencil, size: 18) %>
            <% end %>
            <%= button_to vendor_registration_path(vendor_registration), method: :delete, data: { turbo_confirm: "Delete this vendor registration?" }, class: "app-action-icon text-danger", title: "Delete" do %>
              <%= app_icon(:trash, size: 18) %>
            <% end %>
          </div>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
</div>
<% end %>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    const selectAllCheckbox = document.getElementById("select_all_checkbox");
    const rowCheckboxes = document.querySelectorAll(".row-approval-checkbox");
    const button = document.getElementById("send_for_approval_button");

    function toggleButton() {
      const anyChecked = Array.from(rowCheckboxes).some(cb => cb.checked);
      if (anyChecked) {
        button.classList.remove("d-none");
      } else {
        button.classList.add("d-none");
      }
    }

    if (selectAllCheckbox) {
      selectAllCheckbox.addEventListener("change", function() {
        rowCheckboxes.forEach(cb => cb.checked = this.checked);
        toggleButton();
      });
    }

    rowCheckboxes.forEach(cb => {
      cb.addEventListener("change", function() {
        if (!this.checked && selectAllCheckbox) selectAllCheckbox.checked = false;
        
        const allChecked = Array.from(rowCheckboxes).every(cb => cb.checked);
        if (allChecked && selectAllCheckbox) selectAllCheckbox.checked = true;
        
        toggleButton();
      });
    });
  });
</script>
